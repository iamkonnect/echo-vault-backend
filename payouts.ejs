<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payouts - EchoVault Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/pub/all.min.css">
    <style>
        body { background-color: #0a0a0a; color: white; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.05); border-radius: 1rem; }
        .sidebar { background: rgba(15,12,41,0.8); backdrop-filter: blur(10px); border-right: 1px solid rgba(255,255,255,0.05); }
        .card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px); }
        .sidebar { background-color: #121212; border-right: 1px solid #222; }
        .card { background-color: #1a1a1a; border: 1px solid #333; }
        .table-row { background-color: #1a1a1a; transition: transform 0.2s; }
        .table-row:hover { transform: scale(1.005); background-color: #222; }
    </style>
</head>
<body class="flex h-screen">
    <!-- Sidebar -->
    <div class="sidebar w-64 flex-shrink-0 flex flex-col">
        <div class="p-6 text-2xl font-bold text-purple-500">EchoVault</div>
        <nav class="flex-1 px-4 space-y-2">
            <a href="/api/admin/dashboard" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg">
                <i class="fas fa-chart-pie mr-3 w-5"></i> Dashboard
            </a>
            <a href="/api/admin/payouts" class="flex items-center p-3 text-white bg-purple-500/10 border-l-4 border-purple-500 rounded-r-lg">
                <i class="fas fa-money-check-alt mr-3 w-5 text-purple-500"></i> Payouts
            </a>
            <a href="/api/admin/reports" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg">
                <i class="fas fa-file-alt mr-3 w-5"></i> Reports
            </a>
        </nav>
        <div class="p-4 border-t border-gray-800">
            <form action="/api/auth/logout" method="POST">
                <button type="submit" class="w-full text-left p-3 text-red-400 hover:text-red-300 transition">
                    <i class="fas fa-sign-out-alt mr-3"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1 overflow-y-auto p-8">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-bold">Payout Management</h1>
                <p class="text-gray-400">Platform Revenue: $<%= platformRevenue.toFixed(2) %> 
                    <% if (revenueBreakdown) { %>
                        (Gifts: $<%= revenueBreakdown.gifts.toFixed(2) %> | Music: $<%= revenueBreakdown.music.toFixed(2) %> | Live: $<%= revenueBreakdown.live.toFixed(2) %> | Ads: $<%= revenueBreakdown.ads.toFixed(2) %>)
                    <% } %>
                </p>
            </div>
            <button onclick="openWithdrawModal()" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl font-semibold flex items-center shadow-lg">
                <i class="fas fa-university mr-2"></i> Withdraw to Bank
            </button>
        </div>

        <!-- Platform Withdrawal Modal -->
        <div id="withdrawModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center z-50 p-4" onclick="closeWithdrawModal(event)">
            <div class="bg-gray-900 border border-gray-700 rounded-2xl p-8 max-w-md w-full max-h-screen overflow-y-auto" onclick="event.stopPropagation()">
                <h2 class="text-2xl font-bold mb-6 flex items-center text-green-400">
                    <i class="fas fa-university mr-3"></i>Platform Withdrawal
                </h2>
                <form id="withdrawForm">
                    <div class="space-y-4 mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Amount ($)</label>
                        <input type="number" id="withdrawAmount" step="0.01" min="10" class="w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-white focus:border-green-500 focus:ring-1 focus:ring-green-500" placeholder="e.g. 1000.00" required>

                        <label class="block text-sm font-medium text-gray-300 mb-2">Bank Account</label>
                        <input type="text" id="bankAccount" class="w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-white focus:border-green-500" placeholder="1234-5678-9012" required>

                        <label class="block text-sm font-medium text-gray-300 mb-2">Bank Name</label>
                        <input type="text" id="bankName" class="w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-white focus:border-green-500" placeholder="Example Bank" required>
                    </div>
                    <div class="flex gap-3 pt-4">
                        <button type="button" onclick="closeWithdrawModal()" class="flex-1 bg-gray-700 hover:bg-gray-600 text-white py-3 px-6 rounded-lg transition">Cancel</button>
                        <button type="submit" class="flex-1 bg-green-600 hover:bg-green-700 text-white py-3 px-6 rounded-lg font-semibold transition">Withdraw Now</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Payout Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="card p-6 rounded-xl">
                <p class="text-gray-400 text-sm mb-1">Total Pending</p>
                <h3 class="text-2xl font-bold text-yellow-400">$<%= totalPending.toFixed(2) %></h3>
            </div>
            <div class="card p-6 rounded-xl">
                <p class="text-gray-400 text-sm mb-1">Total Processed (Last 30 Days)</p>
                <h3 class="text-2xl font-bold text-green-400">$<%= totalProcessed.toFixed(2) %></h3>
            </div>
            <div class="card p-6 rounded-xl">
                <p class="text-gray-400 text-sm mb-1">Next Payout Date</p>
                <h3 class="text-2xl font-bold text-blue-400"><%= nextPayoutDate %></h3>
            </div>
        </div>

        <!-- Recent Payout Requests Table -->
        <div class="bg-gray-900/30 rounded-3xl border border-gray-800 overflow-hidden">
            <div class="p-6 border-b border-gray-800 flex justify-between items-center">
                <h3 class="font-bold">Recent Payout Requests</h3>
                <i class="fas fa-history text-gray-600"></i>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-black/20 text-xs text-gray-500 uppercase">
                        <tr>
                            <th class="px-6 py-4 text-left">Artist</th>
                            <th class="px-6 py-4 text-left">Amount</th>
                            <th class="px-6 py-4 text-left">Requested Date</th>
                            <th class="px-6 py-4 text-center">Status</th>
                            <th class="px-6 py-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/50">
                        <% if (payouts && payouts.length > 0) { %>
                            <% payouts.forEach(payout => { %>
                                <tr class="table-row text-sm">
                                    <td class="px-6 py-4 font-medium"><%= payout.artistName %></td>
                                    <td class="px-6 py-4 text-green-400 font-bold">$<%= payout.amount.toFixed(2) %></td>
                                    <td class="px-6 py-4 text-gray-300"><%= new Date(payout.requestedDate).toLocaleDateString() %></td>
                                    <td class="px-6 py-4 text-center"><span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase <%= payout.status === 'COMPLETED' ? 'bg-green-500/10 text-green-500' : payout.status === 'PENDING' ? 'bg-yellow-500/10 text-yellow-500' : 'bg-red-500/10 text-red-500' %>"><%= payout.status %></span></td>
                                    <td class="px-6 py-4 text-center">
                                        <button onclick="viewPayoutDetails('<%= payout.id %>')" class="text-blue-400 hover:text-blue-300 mr-2 p-2 rounded hover:bg-blue-500/20" title="View">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <% if (payout.status === 'PENDING') { %>
                                            <button onclick="approvePayout('<%= payout.id %>')" class="text-green-400 hover:text-green-300 p-2 rounded hover:bg-green-500/20 mr-1" title="Approve">
                                                <i class="fas fa-check"></i>
                                            </button>
                                            <button onclick="rejectPayout('<%= payout.id %>')" class="text-red-400 hover:text-red-300 p-2 rounded hover:bg-red-500/20" title="Reject">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="5" class="px-6 py-12 text-center text-gray-600">No payout requests found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <script>
            function approvePayout(id) {
                if (confirm('Approve this payout?')) {
                    fetch(`/api/admin/payouts/${id}/approve`, { method: 'POST' })
                        .then(r => r.json())
                        .then(data => {
                            alert(data.message);
                            location.reload();
                        })
                        .catch(e => alert('Error: ' + e));
                }
            }

            function rejectPayout(id) {
                const reason = prompt('Reason for rejection (optional):');
                if (confirm('Reject this payout?')) {
                    fetch(`/api/admin/payouts/${id}/reject`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reason })
                    })
                        .then(r => r.json())
                        .then(data => {
                            alert(data.message);
                            location.reload();
                        })
                        .catch(e => alert('Error: ' + e));
                }
            }

            function viewPayoutDetails(id) {
                alert('View details for payout ' + id + ' (Future feature)');
            }

            function openWithdrawModal() {
                document.getElementById('withdrawModal').classList.remove('hidden');
            }

            function closeWithdrawModal(event) {
                document.getElementById('withdrawModal').classList.add('hidden');
            }

            document.getElementById('withdrawForm')?.addEventListener('submit', function(e) {
                e.preventDefault();
                const amount = document.getElementById('withdrawAmount').value;
                const bankAccount = document.getElementById('bankAccount').value;
                const bankName = document.getElementById('bankName').value;

                fetch('/api/admin/platform-withdraw', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount, bankAccount, bankName })
                })
                    .then(r => r.json())
                    .then(data => {
                        alert(data.message);
                        closeWithdrawModal();
                        location.reload();
                    })
                    .catch(e => alert('Withdrawal error: ' + e));
            });
        </script>
    </div>
</body>
</html>
</html>
