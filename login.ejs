<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | EchoVault Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #065F46 0%, #0D9488 50%, #14B8A6 100%);
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
        }
        .glass {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1.5rem;
        }
        .glass-input {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        .glass-input:focus-within {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(168, 85, 247, 0.5);
        }
    </style>
</head>
<body class="flex flex-col items-center justify-center p-6 min-h-screen">
    <!-- Logo & Subtitle - Single Line -->
    <div class="text-center mb-20 lg:mb-28 z-10">
        <i class="fas fa-headphones text-4xl lg:text-5xl text-white/90 mb-6 drop-shadow-xl"></i>
        <h1 class="text-4xl lg:text-6xl font-black bg-gradient-to-r from-purple-400 via-pink-400 to-indigo-400 bg-clip-text text-transparent tracking-[0.2em] uppercase leading-none drop-shadow-2xl mb-4">EchoVault</h1>
        <p class="text-lg lg:text-xl text-white/70 font-light tracking-wide">Welcome back to the sound</p>
    </div>

    <!-- Forms Container -->
    <div class="w-full max-w-5xl flex flex-col lg:flex-row gap-8 justify-center items-stretch -mt-12 lg:-mt-16">
        <!-- Artist Login with Sign Up link -->
        <div class="glass p-8 lg:p-10 flex-1 max-w-lg shadow-2xl hover:shadow-3xl transition-all duration-500 bg-gradient-to-b from-purple-500/5 relative">
            <div class="w-14 h-14 bg-gradient-to-br from-purple-400/40 to-indigo-400/40 rounded-xl flex items-center justify-center mb-5 hover:rotate-12 transition-transform duration-300 absolute -top-8 left-1/2 transform -translate-x-1/2 shadow-lg">
                <i class="fas fa-music text-lg text-purple-200"></i>
            </div>
            <div class="pt-16">
                <h3 class="text-xl lg:text-2xl font-bold text-white mb-2">Artist Login</h3>
                <p class="text-purple-300 mb-8 opacity-90 text-center">Music dashboard & earnings</p>
                <form action="/api/auth/login-dashboard" method="POST" class="space-y-5">
                    <input type="hidden" name="role" value="ARTIST">
                    <div class="glass-input flex items-center px-4 py-3 rounded-xl">
                        <i class="fas fa-envelope text-white/40 mr-3"></i>
                        <input type="email" name="email" placeholder="Email" required class="bg-transparent flex-1 py-2 text-white placeholder-white/50">
                    </div>
                    <div class="glass-input flex items-center px-4 py-3 rounded-xl">
                        <i class="fas fa-lock text-white/40 mr-3"></i>
                        <input type="password" name="password" placeholder="Password" required class="bg-transparent flex-1 py-2 text-white placeholder-white/50">
                    </div>
                    <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 text-white font-bold py-4 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-purple-400/30 text-sm tracking-wide uppercase">
                        Artist Portal
                    </button>
                </form>
                <p class="text-center mt-6 pt-6 border-t border-white/10 text-xs text-white/60 hover:text-purple-300 transition-colors cursor-pointer">
                    Don't have an account? <span class="font-semibold text-purple-400 hover:text-purple-300">Sign Up</span>
                </p>
            </div>
        </div>

        <!-- Admin Login (unchanged) -->
        <div class="glass p-8 lg:p-10 flex-1 max-w-lg shadow-2xl hover:shadow-3xl transition-all duration-500 bg-gradient-to-b from-emerald-500/5 relative">
            <div class="w-14 h-14 bg-gradient-to-br from-emerald-400/40 to-teal-400/40 rounded-xl flex items-center justify-center mb-5 hover:rotate-12 transition-transform duration-300 absolute -top-8 left-1/2 transform -translate-x-1/2 shadow-lg">
                <i class="fas fa-shield-alt text-lg text-emerald-200"></i>
            </div>
            <div class="pt-16">
                <h3 class="text-xl lg:text-2xl font-bold text-white mb-2">Admin Login</h3>
                <p class="text-emerald-300 mb-8 opacity-90 text-center">Platform management</p>
                <form action="/api/auth/login-dashboard" method="POST" class="space-y-5">
                    <input type="hidden" name="role" value="ADMIN">
                    <div class="glass-input flex items-center px-4 py-3 rounded-xl">
                        <i class="fas fa-envelope text-white/40 mr-3"></i>
                        <input type="email" name="email" placeholder="Email" required class="bg-transparent flex-1 py-2 text-white placeholder-white/50">
                    </div>
                    <div class="glass-input flex items-center px-4 py-3 rounded-xl">
                        <i class="fas fa-lock text-white/40 mr-3"></i>
                        <input type="password" name="password" placeholder="Password" required class="bg-transparent flex-1 py-2 text-white placeholder-white/50">
                    </div>
                    <button type="submit" class="w-full bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white font-bold py-4 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-emerald-400/30 text-sm tracking-wide uppercase">
                        Admin Control
                    </button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
