<!-- UPDATED: Top Artists Table - NOW USING REAL DATA -->
<div class="glass p-8 border border-white/10 mb-8">
    <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <i class="fas fa-microphone text-pink-400"></i> Top Artists
    </h3>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-white/5 border-b border-white/10">
                <tr>
                    <th class="px-4 py-3 text-left font-semibold text-white">#</th>
                    <th class="px-4 py-3 text-left font-semibold text-white">Artist Name</th>
                    <th class="px-4 py-3 text-left font-semibold text-white">Total Streams</th>
                    <th class="px-4 py-3 text-left font-semibold text-white">Followers</th>
                    <th class="px-4 py-3 text-left font-semibold text-white">Revenue</th>
                </tr>
            </thead>
            <tbody>
                <% if (stats.topArtists && stats.topArtists.length > 0) { %>
                    <% stats.topArtists.forEach(artist => { %>
                        <tr class="border-t border-white/10 hover:bg-white/5 transition">
                            <td class="px-4 py-3 text-pink-400 font-bold"><%= artist.rank %></td>
                            <td class="px-4 py-3 text-white"><%= artist.name %></td>
                            <td class="px-4 py-3 text-white/70"><%= (artist.totalStreams / 1000000).toFixed(1) %>M</td>
                            <td class="px-4 py-3 text-white/70"><%= (artist.followers / 1000).toFixed(0) %>K</td>
                            <td class="px-4 py-3 text-green-400 font-bold">$<%= artist.revenue.toLocaleString() %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr class="border-t border-white/10">
                        <td colspan="5" class="px-4 py-6 text-center text-white/50">No artists yet</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

