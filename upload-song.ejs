<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Music - EchoVault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #1e3a8a 100%); color: white; font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.05); border-radius: 1rem; }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-2xl">
        <div class="glass p-12">
            <div class="mb-8 text-center">
                <i class="fas fa-music text-6xl text-blue-400 mb-4"></i>
                <h1 class="text-4xl font-bold mb-2">Upload Song</h1>
                <p class="text-gray-400">Share your music with the world</p>
            </div>

            <form id="uploadForm" class="space-y-6">
                <!-- Song Title -->
                <div>
                    <label class="block text-sm font-medium mb-2">Song Title *</label>
                    <input type="text" id="title" name="title" required
                           class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-blue-400 focus:outline-none"
                           placeholder="Enter song title">
                </div>

                <!-- Artist Name -->
                <div>
                    <label class="block text-sm font-medium mb-2">Artist Name *</label>
                    <input type="text" id="artist" name="artist" required
                           class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-blue-400 focus:outline-none"
                           placeholder="Your artist name">
                </div>

                <!-- Duration -->
                <div>
                    <label class="block text-sm font-medium mb-2">Duration (seconds) *</label>
                    <input type="number" id="duration" name="duration" required min="1"
                           class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-blue-400 focus:outline-none"
                           placeholder="Enter duration in seconds">
                </div>

                <!-- File Upload -->
                <div>
                    <label class="block text-sm font-medium mb-2">Audio File (MP3, WAV, FLAC) *</label>
                    <div class="relative">
                        <input type="file" id="file" name="file" accept="audio/*" required
                               class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white focus:border-blue-400 focus:outline-none">
                        <span class="text-xs text-gray-400 mt-1 block">Max file size: 100MB</span>
                    </div>
                </div>

                <!-- Description -->
                <div>
                    <label class="block text-sm font-medium mb-2">Description</label>
                    <textarea id="description" name="description"
                              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-blue-400 focus:outline-none"
                              placeholder="Describe your song"
                              rows="4"></textarea>
                </div>

                <!-- Upload Button -->
                <button type="submit" 
                        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition-all">
                    <i class="fas fa-upload mr-2"></i> Upload Song
                </button>

                <p class="text-center text-gray-400 text-sm">
                    <a href="javascript:history.back()" class="text-blue-400 hover:underline">← Back to Dashboard</a>
                </p>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('uploadForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData();
            formData.append('title', document.getElementById('title').value);
            formData.append('duration', document.getElementById('duration').value);
            formData.append('file', document.getElementById('file').files[0]);

            const token = localStorage.getItem('auth_token');
            
            try {
                const response = await fetch('/api/artist/upload-music', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`
                    },
                    body: formData
                });

                if (response.ok) {
                    alert('Song uploaded successfully!');
                    window.history.back();
                } else {
                    alert('Upload failed: ' + await response.text());
                }
            } catch (error) {
                alert('Error uploading song: ' + error.message);
            }
        });
    </script>
</body>
</html>
