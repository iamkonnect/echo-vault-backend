<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Directory - EchoVault Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { 
            background: linear-gradient(135deg, #0F0C29 0%, #302B63 50%, #24243E 100%); 
            color: white; 
            font-family: 'Inter', sans-serif; 
        }
        .glass { 
            background: rgba(255, 255, 255, 0.03); 
            backdrop-filter: blur(15px); 
            border: 1px solid rgba(255,255,255,0.05); 
            border-radius: 1rem; 
        }
        .admin-sidebar { 
            background: rgba(15, 12, 41, 0.8); 
            backdrop-filter: blur(10px); 
            height: 100vh;
            position: sticky;
            top: 0;
        }
        
        .user-row {
            transition: all 0.3s ease;
        }
        
        .user-row:hover {
            background: rgba(168, 85, 247, 0.1);
        }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }
        
        .status-online {
            background: rgba(16, 185, 129, 0.2);
            color: #6ee7b7;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        
        .status-offline {
            background: rgba(107, 114, 128, 0.2);
            color: #d1d5db;
            border: 1px solid rgba(107, 114, 128, 0.3);
        }
        
        .role-badge {
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: bold;
        }
        
        .role-admin {
            background: rgba(239, 68, 68, 0.2);
            color: #fca5a5;
        }
        
        .role-artist {
            background: rgba(168, 85, 247, 0.2);
            color: #d8b4fe;
        }
        
        .role-user {
            background: rgba(59, 130, 246, 0.2);
            color: #93c5fd;
        }
        
        .ip-tag {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-family: 'Monaco', monospace;
        }

        .filter-btn {
            padding: 8px 16px;
            border-radius: 6px;
            background: rgba(168, 85, 247, 0.1);
            border: 1px solid rgba(168, 85, 247, 0.3);
            color: #d8b4fe;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: bold;
            font-size: 12px;
        }

        .filter-btn:hover {
            background: rgba(168, 85, 247, 0.2);
            border-color: rgba(168, 85, 247, 0.5);
        }

        .filter-btn.active {
            background: rgba(168, 85, 247, 0.3);
            border-color: rgba(168, 85, 247, 0.8);
        }
    </style>
</head>
<body class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-72 admin-sidebar p-8 border-r border-white/5 flex flex-col justify-between">
        <div>
            <div class="flex items-center gap-3 mb-12 pb-8 border-b border-white/10">
                <div class="bg-gradient-to-br from-emerald-500 to-teal-500 p-3 rounded-xl shadow-lg">
                    <i class="fas fa-shield-alt text-white text-xl"></i>
                </div>
                <span class="font-black tracking-tight text-xl bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent">ADMIN CENTRAL</span>
            </div>
            <nav class="space-y-2">
                <div class="text-xs text-white/30 uppercase tracking-wider mb-4 font-medium">Overview</div>
                <a href="/api/admin/dashboard" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-chart-line w-5"></i> Dashboard
                </a>
                <a href="/api/admin/reports" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-flag w-5"></i> Reports
                </a>
                
                <div class="text-xs text-white/30 uppercase tracking-wider mt-8 mb-4 font-medium">Management</div>
                <a href="/api/admin/users" class="flex items-center gap-3 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 font-medium">
                    <i class="fas fa-users w-5"></i> User Directory
                </a>
                <a href="/api/admin/artist-verification" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-microphone w-5"></i> Artist Verification
                </a>
                <a href="/api/admin/create-admin" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-user-plus w-5"></i> Add Admin
                </a>
            </nav>
        </div>
        <button onclick="logout()" class="w-full flex items-center justify-center gap-2 p-3 bg-red-600/20 text-red-400 hover:bg-red-600/30 rounded-lg transition border border-red-600/30">
            <i class="fas fa-sign-out-alt"></i> Logout
        </button>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-12 overflow-y-auto">
        <!-- Header -->
        <div class="mb-12">
            <h1 class="text-5xl font-black bg-gradient-to-r from-emerald-400 via-teal-400 to-emerald-600 bg-clip-text text-transparent tracking-tight mb-2">User Directory</h1>
            <p class="text-white/60 text-lg">Monitor all users, artists, and admins on the platform</p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
            <div class="glass p-6 border border-emerald-500/20 hover:border-emerald-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-emerald-500/20 rounded-xl"><i class="fas fa-users text-emerald-400"></i></span>
                    <span class="text-emerald-400 text-sm font-bold">Total</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">All Users</p>
                <p class="text-4xl font-black"><%= users.length %></p>
            </div>

            <div class="glass p-6 border border-purple-500/20 hover:border-purple-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-purple-500/20 rounded-xl"><i class="fas fa-microphone text-purple-400"></i></span>
                    <span class="text-purple-400 text-sm font-bold">Artists</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">Active Artists</p>
                <p class="text-4xl font-black"><%= users.filter(u => u.role === 'ARTIST').length %></p>
            </div>

            <div class="glass p-6 border border-blue-500/20 hover:border-blue-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-blue-500/20 rounded-xl"><i class="fas fa-user text-blue-400"></i></span>
                    <span class="text-blue-400 text-sm font-bold">Listeners</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">Active Listeners</p>
                <p class="text-4xl font-black"><%= users.filter(u => u.role === 'USER').length %></p>
            </div>

            <div class="glass p-6 border border-green-500/20 hover:border-green-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-green-500/20 rounded-xl"><i class="fas fa-circle text-green-400"></i></span>
                    <span class="text-green-400 text-sm font-bold">Online</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">Online Now</p>
                <p class="text-4xl font-black"><%= users.filter(u => u.isOnline).length %></p>
            </div>
        </div>

        <!-- Filters -->
        <div class="flex gap-2 mb-6">
            <button class="filter-btn active" onclick="filterUsers('all')">All Users</button>
            <button class="filter-btn" onclick="filterUsers('artist')">Artists Only</button>
            <button class="filter-btn" onclick="filterUsers('user')">Listeners Only</button>
            <button class="filter-btn" onclick="filterUsers('online')">Online</button>
        </div>

        <!-- Users Table -->
        <div class="glass overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-white/5 text-white/40 text-sm uppercase">
                        <tr>
                            <th class="p-4">User</th>
                            <th class="p-4">Role</th>
                            <th class="p-4">Status</th>
                            <th class="p-4">Last Login IP</th>
                            <th class="p-4">Region</th>
                            <th class="p-4">Last Seen</th>
                            <th class="p-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% users.forEach(user => { %>
                        <tr class="user-row">
                            <td class="p-4">
                                <div>
                                    <p class="font-semibold text-white"><%= user.name %></p>
                                    <p class="text-sm text-white/50"><%= user.email %></p>
                                </div>
                            </td>
                            <td class="p-4">
                                <span class="role-badge role-<%= user.role.toLowerCase() %>">
                                    <% if (user.role === 'ADMIN') { %>
                                        <i class="fas fa-crown"></i> Admin
                                    <% } else if (user.role === 'ARTIST') { %>
                                        <i class="fas fa-microphone"></i> Artist
                                    <% } else { %>
                                        <i class="fas fa-user"></i> Listener
                                    <% } %>
                                </span>
                            </td>
                            <td class="p-4">
                                <span class="status-badge <%= user.isOnline ? 'status-online' : 'status-offline' %>">
                                    <span class="w-2 h-2 rounded-full <%= user.isOnline ? 'bg-green-400' : 'bg-gray-400' %>"></span>
                                    <%= user.isOnline ? 'Online' : 'Offline' %>
                                </span>
                            </td>
                            <td class="p-4">
                                <% if (user.lastLoginIp) { %>
                                    <span class="ip-tag"><%= user.lastLoginIp %></span>
                                <% } else { %>
                                    <span class="text-white/30 text-sm">No login yet</span>
                                <% } %>
                            </td>
                            <td class="p-4">
                                <% if (user.lastLoginRegion) { %>
                                    <span class="text-sm text-white/70">
                                        <i class="fas fa-map-marker-alt text-red-400"></i>
                                        <%= user.lastLoginRegion %>
                                    </span>
                                <% } else { %>
                                    <span class="text-white/30 text-sm">Unknown</span>
                                <% } %>
                            </td>
                            <td class="p-4">
                                <% if (user.lastLogin) { %>
                                    <span class="text-sm text-white/70"><%= new Date(user.lastLogin).toLocaleDateString() %></span>
                                <% } else { %>
                                    <span class="text-white/30 text-sm">Never</span>
                                <% } %>
                            </td>
                            <td class="p-4">
                                <a href="/api/admin/users/<%= user.id %>" class="text-purple-400 hover:text-purple-300 text-sm font-semibold">View</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% if (users.length === 0) { %>
                <p class="text-white/30 text-center p-8">No users found.</p>
            <% } %>
        </div>
    </main>

    <script>
        function filterUsers(type) {
            // Remove active class from all buttons
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            
            // Add active class to clicked button
            event.target.classList.add('active');
            
            // Show/hide rows based on filter
            const rows = document.querySelectorAll('.user-row');
            rows.forEach(row => {
                const roleText = row.querySelector('[class*="role-"]').textContent.toLowerCase();
                const statusText = row.querySelector('[class*="status-"]').textContent.toLowerCase();
                
                let show = false;
                if (type === 'all') show = true;
                else if (type === 'artist') show = roleText.includes('artist');
                else if (type === 'user') show = roleText.includes('listener');
                else if (type === 'online') show = statusText.includes('online');
                
                row.style.display = show ? '' : 'none';
            });
        }

        function logout() {
            if (confirm('Are you sure you want to logout?')) {
                fetch('/api/auth/logout', { method: 'POST' })
                    .then(() => window.location.href = '/')
                    .catch(err => console.error('Logout error:', err));
            }
        }
    </script>
</body>
</html>
