        function exportXML() {
            const dateRange = document.getElementById('dateRangeDisplay').textContent;
            const artistName = '<%= user.name %>';
            const currentDate = new Date().toISOString();
            
            let xmlContent = '<?xml version="1.0" encoding="UTF-8"?>\n';
            xmlContent += '<ChannelAnalyticsReport>\n';
            xmlContent += `  <Header>\n`;
            xmlContent += `    <Artist>${escapeXml(artistName)}</Artist>\n`;
            xmlContent += `    <ReportPeriod>${escapeXml(dateRange)}</ReportPeriod>\n`;
            xmlContent += `    <GeneratedDate>${currentDate}</GeneratedDate>\n`;
            xmlContent += `  </Header>\n\n`;
            
            // Key Metrics
            xmlContent += `  <KeyPerformanceIndicators>\n`;
            xmlContent += `    <Metric name="Total Views" value="156.2K" change="+12.5%"/>\n`;
            xmlContent += `    <Metric name="Engagement Rate" value="8.4%" change="+2.1%"/>\n`;
            xmlContent += `    <Metric name="New Followers" value="2450" change="+18.3%"/>\n`;
            xmlContent += `    <Metric name="Revenue" value="$4250" change="+9.2%"/>\n`;
            xmlContent += `  </KeyPerformanceIndicators>\n\n`;
            
            // Top Performing Content
            xmlContent += `  <TopPerformingContent>\n`;
            const contentData = [
                { title: 'Summer Hits Mix', views: '15420', engagement: '2340', revenue: '$1250' },
                { title: 'Live Performance NYC', views: '12890', engagement: '3210', revenue: '$980' },
                { title: 'Studio Session Vlog', views: '9870', engagement: '1890', revenue: '$750' },
                { title: 'Behind The Scenes', views: '7654', engagement: '1200', revenue: '$450' }
            ];
            contentData.forEach(item => {
                xmlContent += `    <Content title="${escapeXml(item.title)}" views="${item.views}" engagement="${item.engagement}" revenue="${item.revenue}"/>\n`;
            });
            xmlContent += `  </TopPerformingContent>\n\n`;
            
            // Revenue Metrics
            xmlContent += `  <RevenueMetrics>\n`;
            xmlContent += `    <TotalRevenue>$12450</TotalRevenue>\n`;
            xmlContent += `    <AveragePerAudio>$450</AveragePerAudio>\n`;
            xmlContent += `    <AveragePerVideo>$650</AveragePerVideo>\n`;
            xmlContent += `    <AveragePerShorts>$280</AveragePerShorts>\n`;
            xmlContent += `    <AveragePerLiveStream>$820</AveragePerLiveStream>\n`;
            xmlContent += `    <RevenuePer1KViews>$2.15</RevenuePer1KViews>\n`;
            xmlContent += `  </RevenueMetrics>\n`;
            
            xmlContent += `</ChannelAnalyticsReport>`;
            
            // Create download link
            const blob = new Blob([xmlContent], { type: 'application/xml' });
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `Channel-Analytics-${artistName.replace(/\s+/g, '-')}-${new Date().toISOString().split('T')[0]}.xml`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            window.URL.revokeObjectURL(url);
            
            document.getElementById('exportMenu').classList.add('hidden');
            document.getElementById('exportChevron').style.transform = 'rotate(0deg)';
        }
        
        // Helper function to escape XML special characters
        function escapeXml(unsafe) {
            return unsafe.replace(/[<>&'"]/g, function (c) {
                switch (c) {
                    case '<': return '&lt;';
                    case '>': return '&gt;';
                    case '&': return '&amp;';
                    case '\'': return '&apos;';
                    case '"': return '&quot;';
                }
            });
        }

