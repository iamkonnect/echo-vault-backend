            document.getElementById('dateRangeDisplay').textContent = labels[range];
            document.getElementById('dateDropdown').classList.add('hidden');
            console.log('Date range changed to:', range);
            // Fetch new data based on date range
            loadAnalyticsData(range);
        }

        function applyCustomRange() {
            const startDate = document.getElementById('customStartDate').value;
            const endDate = document.getElementById('customEndDate').value;
            if (startDate && endDate) {
                document.getElementById('dateRangeDisplay').textContent = `${startDate} to ${endDate}`;
                document.getElementById('dateDropdown').classList.add('hidden');
                console.log('Custom range applied:', startDate, 'to', endDate);
