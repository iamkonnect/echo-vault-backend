                                'rgba(236, 72, 153, 0.8)',
                                'rgba(236, 72, 153, 0.7)',
                                'rgba(236, 72, 153, 0.6)',
                                'rgba(236, 72, 153, 0.7)',
                                'rgba(236, 72, 153, 0.8)'
                            ],
                            borderColor: '#be123c',
                            borderWidth: 1,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        ...chartConfig,
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(107, 114, 128, 0.1)', drawBorder: false },
                                ticks: { color: '#9ca3af', font: { size: 12 } }
                            },
                            x: {
                                grid: { display: false, drawBorder: false },
                                ticks: { color: '#9ca3af', font: { size: 12 } }
                            }
                        }
                    }
                });
            }

            // Age Demographics Chart
            const ageCtx = document.getElementById('ageChart');
            if (ageCtx && !charts.age) {
                charts.age = new Chart(ageCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Age 13-24', 'Age 25-34', 'Age 35-44', 'Age 45+'],
                        datasets: [{
                            data: [45, 30, 16, 9],
                            backgroundColor: [
                                'rgba(59, 130, 246, 0.8)',
                                'rgba(139, 92, 246, 0.8)',
                                'rgba(236, 72, 153, 0.8)',
                                'rgba(245, 158, 11, 0.8)'
                            ],
                            borderColor: '#1f2937',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        ...chartConfig,
                        plugins: {
                            ...chartConfig.plugins,
                            datalabels: {
                                color: '#fff',
                                font: { weight: 'bold' }
                            }
                        }
                    }
                });
            }

            // Gender Demographics Chart
            const genderCtx = document.getElementById('genderChart');
            if (genderCtx && !charts.gender) {
                charts.gender = new Chart(genderCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Female', 'Male'],
                        datasets: [{
                            data: [52, 48],
                            backgroundColor: [
                                'rgba(236, 72, 153, 0.8)',
                                'rgba(59, 130, 246, 0.8)'
                            ],
                            borderColor: '#1f2937',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        ...chartConfig,
                        plugins: {
                            ...chartConfig.plugins,
                            datalabels: {
                                color: '#fff',
                                font: { weight: 'bold' }
                            }
                        }
                    }
                });
            }

            // Revenue Chart
            const revenueCtx = document.getElementById('revenueChart');
            if (revenueCtx && !charts.revenue) {
                charts.revenue = new Chart(revenueCtx, {
                    type: 'bar',
                    data: {
                        labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                        datasets: [{
                            label: 'Revenue ($)',
                            data: [2210, 2890, 3500, 2800],
                            backgroundColor: 'rgba(16, 185, 129, 0.8)',
                            borderColor: '#059669',
                            borderWidth: 1,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        ...chartConfig,
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(107, 114, 128, 0.1)', drawBorder: false },
                                ticks: { color: '#9ca3af', font: { size: 12 }, callback: function(value) { return '$' + value; } }
                            },
                            x: {
                                grid: { display: false, drawBorder: false },
                                ticks: { color: '#9ca3af', font: { size: 12 } }
                            }
                        }
                    }
                });
            }
        }

        // Initialize charts when Overview tab is first opened
        const originalSetActiveTab = setActiveTab;
        window.setActiveTab = function(tabName) {
            originalSetActiveTab(tabName);
            if (tabName === 'overview' && Object.keys(charts).length === 0) {
                setTimeout(() => initializeCharts(), 100);
            }
        };

        // Initialize charts on page load
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => initializeCharts(), 500);
        });
    </script>
</body>
</html>