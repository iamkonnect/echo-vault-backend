<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Artist Dashboard - EchoVault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #0a0a0a; color: white; }
        .sidebar { background-color: #121212; border-right: 1px solid #222; }
        .stat-card { background-color: #1a1a1a; border: 1px solid #333; }
        .active-link { background-color: rgba(168, 85, 247, 0.1); border-left: 4px solid rgb(168, 85, 247); }
    </style>
</head>
<body class="flex h-screen">
    <!-- Sidebar -->
    <div class="sidebar w-64 flex-shrink-0 flex flex-col">
        <div class="p-6 text-2xl font-bold text-purple-500">
            <i class="fas fa-music mr-2"></i>EchoVault
        </div>
        
        <nav class="flex-1 px-4 space-y-2 py-6">
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-4 font-medium px-2">Navigation</div>
            
            <a href="/api/artist/dashboard" class="flex items-center p-3 text-white active-link rounded-r-lg transition-all">
                <i class="fas fa-home mr-3 w-5"></i>
                <span>Dashboard</span>
            </a>
            
            <a href="/api/artist/my-music" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-compact-disc mr-3 w-5"></i>
                <span>My Music</span>
            </a>
            
            <a href="/api/artist/shorts-insights" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-chart-line mr-3 w-5"></i>
                <span>Shorts Insights</span>
            </a>
            
            <a href="/api/artist/live-insights" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-video mr-3 w-5"></i>
                <span>Live Insights</span>
            </a>
            
            <a href="/api/artist/revenue" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-wallet mr-3 w-5"></i>
                <span>Revenue</span>
            </a>
            
            <a href="#analytics" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all" onclick="document.querySelector('[class*=analytics]').scrollIntoView({behavior: 'smooth'}); return false;">
                <i class="fas fa-chart-line mr-3 w-5"></i>
                <span>Channel Analytics</span>
            </a>

            <div class="text-xs text-gray-500 uppercase tracking-wider mt-8 mb-4 font-medium px-2">Upload</div>
            
            <a href="/api/artist/upload/audio" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-music mr-3 w-5"></i>
                <span>Upload Song</span>
            </a>
            
            <a href="/api/artist/upload/video" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-video mr-3 w-5"></i>
                <span>Upload Video</span>
            </a>
            
            <a href="/api/artist/upload/shorts" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-film mr-3 w-5"></i>
                <span>Upload Short</span>
            </a>
        </nav>

        <button onclick="logout()" class="m-4 w-[calc(100%-2rem)] flex items-center justify-center gap-2 p-3 bg-red-600/20 text-red-400 hover:bg-red-600/30 rounded-lg transition-all border border-red-600/30">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </button>
    </div>

    <!-- Main Content -->
    <div class="flex-1 overflow-y-auto p-8">
        <header class="flex justify-between items-center mb-10 pb-8 border-b border-white/10">
            <div>
                <h1 class="text-4xl font-bold text-purple-400 mb-2">Welcome back, <%= user.name %>!</h1>
                <p class="text-gray-400">Track your music performance and earnings</p>
            </div>
            <div class="flex items-center space-x-6">
                <div class="text-right bg-purple-500/10 p-4 rounded-lg border border-purple-500/20">
                    <p class="text-xs text-gray-400 uppercase tracking-wide">Wallet Balance</p>
                    <p class="text-2xl font-bold text-purple-400">$<%= (user.walletBalance || 0).toFixed(2) %></p>
                </div>
                <div class="w-14 h-14 bg-gradient-to-br from-purple-600 to-pink-600 rounded-full flex items-center justify-center font-bold text-lg">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
            </div>
        </header>

        <!-- Key Metrics -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="stat-card p-6 rounded-2xl hover:border-blue-500/50 transition-all">
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-blue-500/10 rounded-lg text-blue-400"><i class="fas fa-play text-xl"></i></div>
                    <span class="text-xs text-green-500 font-bold bg-green-500/10 px-2 py-1 rounded">+12%</span>
                </div>
                <p class="text-gray-400 text-sm mb-2">Total Streams</p>
                <h2 class="text-3xl font-bold">0</h2>
            </div>

            <div class="stat-card p-6 rounded-2xl hover:border-purple-500/50 transition-all">
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-purple-500/10 rounded-lg text-purple-400"><i class="fas fa-users text-xl"></i></div>
                    <span class="text-xs text-green-500 font-bold bg-green-500/10 px-2 py-1 rounded">+5%</span>
                </div>
                <p class="text-gray-400 text-sm mb-2">Monthly Listeners</p>
                <h2 class="text-3xl font-bold">0</h2>
            </div>

            <div class="stat-card p-6 rounded-2xl hover:border-yellow-500/50 transition-all">
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-yellow-500/10 rounded-lg text-yellow-400"><i class="fas fa-compact-disc text-xl"></i></div>
                </div>
                <p class="text-gray-400 text-sm mb-2">Total Releases</p>
                <h2 class="text-3xl font-bold text-yellow-400"><%= stats.contentCount || 0 %></h2>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 mb-10">
            <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
                <i class="fas fa-lightning-bolt text-yellow-400"></i>
                Quick Actions
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <a href="/api/artist/upload/audio" class="p-4 bg-white/5 rounded-xl hover:bg-white/10 transition-all border border-white/5 hover:border-blue-500/30">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                            <i class="fas fa-music text-blue-400"></i>
                        </div>
                        <div>
                            <p class="font-medium">Upload Song</p>
                            <p class="text-xs text-gray-400">Add new music</p>
                        </div>
                    </div>
                </a>
                <a href="/api/artist/my-music" class="p-4 bg-white/5 rounded-xl hover:bg-white/10 transition-all border border-white/5 hover:border-purple-500/30">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center">
                            <i class="fas fa-compact-disc text-purple-400"></i>
                        </div>
                        <div>
                            <p class="font-medium">My Library</p>
                            <p class="text-xs text-gray-400">Manage content</p>
                        </div>
                    </div>
                </a>
                <a href="/api/artist/revenue" class="p-4 bg-white/5 rounded-xl hover:bg-white/10 transition-all border border-white/5 hover:border-green-500/30">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                            <i class="fas fa-wallet text-green-400"></i>
                        </div>
                        <div>
                            <p class="font-medium">Revenue</p>
                            <p class="text-xs text-gray-400">View earnings</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- Channel Analytics Section -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-purple-400 mb-2 flex items-center gap-2">
                    <i class="fas fa-chart-line text-purple-400"></i>
                    Channel Analytics
                </h2>
                <p class="text-gray-400">Track your performance metrics and gain insights into your audience</p>
            </div>

            <!-- Date Range & Export Controls -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 pb-6 border-b border-white/10">
                <!-- Date Range Selector -->
                <div class="relative w-full max-w-sm">
                    <button onclick="toggleDateDropdown()" class="w-full flex items-center gap-2 bg-white/10 border border-white/20 rounded-lg px-4 py-2 text-gray-300 hover:bg-white/20 transition-all">
                        <i class="fas fa-calendar"></i>
                        <span class="flex-1 text-left text-sm font-medium" id="dateRangeDisplay">Last 1 Month</span>
                        <i class="fas fa-chevron-down transition-transform" id="dateChevron"></i>
                    </button>

                    <div id="dateDropdown" class="hidden absolute top-full mt-2 w-full bg-gray-800 border border-white/20 rounded-lg shadow-lg z-50">
                        <div class="border-b border-white/10 p-3">
                            <p class="text-xs font-semibold text-gray-400 uppercase px-2 mb-2">Presets</p>
                            <div class="space-y-1">
                                <button onclick="setDateRange('1month')" class="w-full text-left px-3 py-2 rounded-md text-sm font-medium bg-blue-900/40 text-blue-300 hover:bg-blue-900/60">Last 1 Month</button>
                                <button onclick="setDateRange('3months')" class="w-full text-left px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:bg-white/10">Last 3 Months</button>
                                <button onclick="setDateRange('6months')" class="w-full text-left px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:bg-white/10">Last 6 Months</button>
                                <button onclick="setDateRange('9months')" class="w-full text-left px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:bg-white/10">Last 9 Months</button>
                                <button onclick="setDateRange('1year')" class="w-full text-left px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:bg-white/10">Last 1 Year</button>
                            </div>
                        </div>
                        <div class="border-b border-white/10 p-3">
                            <p class="text-xs font-semibold text-gray-400 uppercase px-2 mb-3">Custom Range</p>
                            <div class="space-y-2">
                                <div>
                                    <label class="block text-xs font-medium text-gray-400 mb-1">Start Date</label>
                                    <input type="date" id="customStartDate" class="w-full px-3 py-2 border border-white/20 rounded-md text-sm bg-gray-700 text-white focus:outline-none focus:ring-2 focus:ring-purple-500">
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-gray-400 mb-1">End Date</label>
                                    <input type="date" id="customEndDate" class="w-full px-3 py-2 border border-white/20 rounded-md text-sm bg-gray-700 text-white focus:outline-none focus:ring-2 focus:ring-purple-500">
                                </div>
                                <button onclick="applyCustomRange()" class="w-full mt-2 px-3 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-md text-sm font-medium transition-all">Apply Custom Range</button>
                            </div>
                        </div>
                        <div class="p-3">
                            <button onclick="toggleDateDropdown()" class="w-full px-3 py-2 text-gray-300 hover:bg-white/10 rounded-md text-sm font-medium transition-all">Close</button>
                        </div>
                    </div>
                </div>

                <!-- Export Button -->
                <div class="relative">
                    <button onclick="toggleExportMenu()" class="flex items-center gap-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg px-4 py-2 font-medium transition-all">
                        <i class="fas fa-download"></i>
                        <span>Export</span>
                        <i class="fas fa-chevron-down transition-transform" id="exportChevron"></i>
                    </button>

                    <div id="exportMenu" class="hidden absolute top-full right-0 mt-2 w-56 bg-gray-800 border border-white/20 rounded-lg shadow-lg z-50">
                        <div class="p-2">
                            <button onclick="exportPDF()" class="w-full text-left px-4 py-3 hover:bg-white/10 rounded-md transition-all">
                                <p class="font-medium text-white text-sm">Export as PDF</p>
                                <p class="text-xs text-gray-400">Professional report with formatting</p>
                            </button>
                            <button onclick="exportCSV()" class="w-full text-left px-4 py-3 hover:bg-white/10 rounded-md transition-all">
                                <p class="font-medium text-white text-sm">Export as CSV</p>
                                <p class="text-xs text-gray-400">For spreadsheet applications</p>
                            </button>
                            <button onclick="exportXML()" class="w-full text-left px-4 py-3 hover:bg-white/10 rounded-md transition-all">
                                <p class="font-medium text-white text-sm">Export as XML</p>
                                <p class="text-xs text-gray-400">For data integration</p>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Key Metrics Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white/5 border border-white/10 rounded-lg p-6 hover:border-blue-500/30 hover:bg-blue-500/5 transition-all">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <p class="text-gray-400 text-sm font-medium mb-2">Total Views</p>
                            <h3 class="text-2xl font-bold text-white mb-2">0</h3>
                            <p class="text-sm font-semibold text-green-500">0%</p>
                        </div>
                        <div class="bg-gradient-to-br from-blue-500 to-cyan-500 p-3 rounded-lg text-white">
                            <i class="fas fa-arrow-trend-up text-xl"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white/5 border border-white/10 rounded-lg p-6 hover:border-purple-500/30 hover:bg-purple-500/5 transition-all">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <p class="text-gray-400 text-sm font-medium mb-2">Engagement Rate</p>
                            <h3 class="text-2xl font-bold text-white mb-2">0%</h3>
                            <p class="text-sm font-semibold text-green-500">0%</p>
                        </div>
                        <div class="bg-gradient-to-br from-purple-500 to-pink-500 p-3 rounded-lg text-white">
                            <i class="fas fa-file-chart-line text-xl"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white/5 border border-white/10 rounded-lg p-6 hover:border-pink-500/30 hover:bg-pink-500/5 transition-all">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <p class="text-gray-400 text-sm font-medium mb-2">New Followers</p>
                            <h3 class="text-2xl font-bold text-white mb-2">0</h3>
                            <p class="text-sm font-semibold text-green-500">0%</p>
                        </div>
                        <div class="bg-gradient-to-br from-pink-500 to-rose-500 p-3 rounded-lg text-white">
                            <i class="fas fa-users text-xl"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white/5 border border-white/10 rounded-lg p-6 hover:border-green-500/30 hover:bg-green-500/5 transition-all">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <p class="text-gray-400 text-sm font-medium mb-2">Revenue</p>
                            <h3 class="text-2xl font-bold text-white mb-2">$0.00</h3>
                            <p class="text-sm font-semibold text-green-500">0%</p>
                        </div>
                        <div class="bg-gradient-to-br from-green-500 to-emerald-500 p-3 rounded-lg text-white">
                            <i class="fas fa-wallet text-xl"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabs Navigation -->
            <div class="bg-white/5 border border-white/10 rounded-lg shadow-md">
                <div class="flex border-b border-white/10">
                    <button onclick="setActiveTab('overview')" class="flex-1 py-4 px-6 font-semibold transition-colors text-center active-tab border-b-2 border-purple-500" id="tab-overview">
                        Overview
                    </button>
                    <button onclick="setActiveTab('content')" class="flex-1 py-4 px-6 font-semibold transition-colors text-center text-gray-400 hover:text-white" id="tab-content">
                        Content
                    </button>
                    <button onclick="setActiveTab('audience')" class="flex-1 py-4 px-6 font-semibold transition-colors text-center text-gray-400 hover:text-white" id="tab-audience">
                        Audience
                    </button>
                    <button onclick="setActiveTab('revenue')" class="flex-1 py-4 px-6 font-semibold transition-colors text-center text-gray-400 hover:text-white" id="tab-revenue">
                        Revenue
                    </button>
                </div>

                <!-- Tab Content -->
                <div class="p-6">
                    <!-- Overview Tab -->
                    <div id="tab-overview-content" class="block">
                        <div class="space-y-8">
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-4">Views & Engagement Trend</h3>
                                <div class="bg-gradient-to-br from-gray-800/30 to-gray-900/30 rounded-lg p-6 border border-white/5">
                                    <canvas id="viewsEngagementChart" style="max-height: 400px;"></canvas>
                                </div>
                            </div>

                            <div>
                                <h3 class="text-lg font-semibold text-white mb-4">Follower Growth</h3>
                                <div class="bg-gradient-to-br from-gray-800/30 to-gray-900/30 rounded-lg p-6 border border-white/5">
                                    <canvas id="followerGrowthChart" style="max-height: 300px;"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Content Tab -->
                    <div id="tab-content-content" class="hidden">
                        <h3 class="text-lg font-semibold text-white mb-4">Top Performing Content</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-white/5 border-b border-white/10">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-white">Content Title</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-white">Views</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-white">Engagement</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-white">Revenue</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-t border-white/10 hover:bg-white/5 transition-colors">
                                        <td colspan="4" class="px-6 py-8 text-center text-gray-400">No content yet. Start creating to see performance metrics.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Audience Tab -->
                    <div id="tab-audience-content" class="hidden">
                        <div class="space-y-8">
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                <div>
                                    <h3 class="text-lg font-semibold text-white mb-4">Audience Demographics by Age</h3>
                                    <div class="bg-gradient-to-br from-gray-800/30 to-gray-900/30 rounded-lg p-6 border border-white/5">
                                        <canvas id="ageChart" style="max-height: 300px;"></canvas>
                                    </div>
                                </div>

                                <div>
                                    <h3 class="text-lg font-semibold text-white mb-4">Audience Demographics by Gender</h3>
                                    <div class="bg-gradient-to-br from-gray-800/30 to-gray-900/30 rounded-lg p-6 border border-white/5">
                                        <canvas id="genderChart" style="max-height: 300px;"></canvas>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <h3 class="text-lg font-semibold text-white mb-4">Top Geographic Locations</h3>
                                <div class="space-y-3">
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-300 font-medium">United States</span>
                                        <div class="flex items-center gap-2 w-48">
                                            <div class="flex-1 bg-white/10 rounded-full h-2 overflow-hidden">
                                                <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-full" style="width: 0%;"></div>
                                            </div>
                                            <span class="text-gray-400 text-sm font-semibold w-12 text-right">0%</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-300 font-medium">United Kingdom</span>
                                        <div class="flex items-center gap-2 w-48">
                                            <div class="flex-1 bg-white/10 rounded-full h-2 overflow-hidden">
                                                <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-full" style="width: 0%;"></div>
                                            </div>
                                            <span class="text-gray-400 text-sm font-semibold w-12 text-right">0%</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-300 font-medium">Canada</span>
                                        <div class="flex items-center gap-2 w-48">
                                            <div class="flex-1 bg-white/10 rounded-full h-2 overflow-hidden">
                                                <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-full" style="width: 0%;"></div>
                                            </div>
                                            <span class="text-gray-400 text-sm font-semibold w-12 text-right">0%</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-300 font-medium">Australia</span>
                                        <div class="flex items-center gap-2 w-48">
                                            <div class="flex-1 bg-white/10 rounded-full h-2 overflow-hidden">
                                                <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-full" style="width: 0%;"></div>
                                            </div>
                                            <span class="text-gray-400 text-sm font-semibold w-12 text-right">0%</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-300 font-medium">Germany</span>
                                        <div class="flex items-center gap-2 w-48">
                                            <div class="flex-1 bg-white/10 rounded-full h-2 overflow-hidden">
                                                <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-full" style="width: 0%;"></div>
                                            </div>
                                            <span class="text-gray-400 text-sm font-semibold w-12 text-right">0%</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Revenue Tab -->
                    <div id="tab-revenue-content" class="hidden">
                        <div class="space-y-8">
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-4">Revenue Trends</h3>
