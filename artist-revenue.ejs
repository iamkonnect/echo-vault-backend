<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Revenue - Artist Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0a0a0a; color: white; }
        .sidebar { background-color: #121212; border-right: 1px solid #222; }
        .card { background-color: #1a1a1a; border: 1px solid #333; }
        .active-link { background-color: rgba(168, 85, 247, 0.1); border-left: 4px solid rgb(168, 85, 247); }
    </style>
</head>
<body class="flex h-screen">
    <!-- Sidebar -->
    <div class="sidebar w-64 flex-shrink-0 flex flex-col">
        <div class="p-6 text-2xl font-bold text-purple-500">
            <i class="fas fa-music mr-2"></i>EchoVault
        </div>
        
        <nav class="flex-1 px-4 space-y-2 py-6">
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-4 font-medium px-2">Navigation</div>
            
            <a href="/api/artist/dashboard" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-home mr-3 w-5"></i>
                <span>Dashboard</span>
            </a>
            
            <a href="/api/artist/my-music" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-compact-disc mr-3 w-5"></i>
                <span>My Music</span>
            </a>
            
            <a href="/api/artist/insights" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-chart-line mr-3 w-5"></i>
                <span>Insights</span>
            </a>
            
            <a href="/api/artist/revenue" class="flex items-center p-3 text-white active-link rounded-r-lg transition-all">
                <i class="fas fa-wallet mr-3 w-5"></i>
                <span>Revenue</span>
            </a>
            
            <a href="/api/artist/live-insights" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-broadcast-tower mr-3 w-5"></i>
                <span>Live Insights</span>
            </a>

            <div class="text-xs text-gray-500 uppercase tracking-wider mt-8 mb-4 font-medium px-2">Upload</div>
            
            <a href="/api/artist/upload-song" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-music mr-3 w-5"></i>
                <span>Upload Song</span>
            </a>
            
            <a href="/api/artist/upload-video" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-video mr-3 w-5"></i>
                <span>Upload Video</span>
            </a>
            
            <a href="/api/artist/upload-shorts" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-film mr-3 w-5"></i>
                <span>Upload Shorts</span>
            </a>
        </nav>

        <button onclick="logout()" class="m-4 w-[calc(100%-2rem)] flex items-center justify-center gap-2 p-3 bg-red-600/20 text-red-400 hover:bg-red-600/30 rounded-lg transition-all border border-red-600/30">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </button>
    </div>

    <!-- Main Content -->
    <div class="flex-1 overflow-y-auto p-8">
        <header class="mb-8 pb-6 border-b border-white/10">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="text-4xl font-bold text-purple-400 mb-2">Revenue Dashboard</h1>
                    <p class="text-gray-400">Track your earnings and payouts</p>
                </div>
                <button class="px-6 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition flex items-center gap-2">
                    <i class="fas fa-arrow-up-right-from-square"></i> Request Withdrawal
                </button>
            </div>
        </header>

        <!-- Total Earnings Card -->
        <div class="card p-8 rounded-lg mb-8 border-l-4 border-green-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-400 text-sm mb-2">Total Earnings</p>
                    <p class="text-5xl font-bold text-white">$0.00</p>
                    <p class="text-green-400 text-sm mt-2">+0% from last month</p>
                </div>
                <i class="fas fa-wallet text-green-400 text-6xl opacity-20"></i>
            </div>
        </div>

        <!-- Revenue Breakdown -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="card p-6 rounded-lg">
                <h3 class="text-sm font-medium text-gray-400 mb-4 flex items-center gap-2">
                    <i class="fas fa-music text-blue-400"></i> Songs Revenue
                </h3>
                <p class="text-3xl font-bold text-white">$0.00</p>
                <p class="text-sm text-gray-500 mt-2">From 0 streams</p>
            </div>

            <div class="card p-6 rounded-lg">
                <h3 class="text-sm font-medium text-gray-400 mb-4 flex items-center gap-2">
                    <i class="fas fa-video text-orange-400"></i> Video Revenue
                </h3>
                <p class="text-3xl font-bold text-white">$0.00</p>
                <p class="text-sm text-gray-500 mt-2">From 0 views</p>
            </div>

            <div class="card p-6 rounded-lg">
                <h3 class="text-sm font-medium text-gray-400 mb-4 flex items-center gap-2">
                    <i class="fas fa-film text-yellow-400"></i> Shorts Revenue
                </h3>
                <p class="text-3xl font-bold text-white">$0.00</p>
                <p class="text-sm text-gray-500 mt-2">From 0 views</p>
            </div>

            <div class="card p-6 rounded-lg">
                <h3 class="text-sm font-medium text-gray-400 mb-4 flex items-center gap-2">
                    <i class="fas fa-broadcast-tower text-red-400"></i> Live Revenue
                </h3>
                <p class="text-3xl font-bold text-white">$0.00</p>
                <p class="text-sm text-gray-500 mt-2">From 0 gifts</p>
            </div>
        </div>

        <!-- Revenue Details Table -->
        <div class="card p-6 rounded-lg mb-8">
            <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                <i class="fas fa-list text-purple-400"></i> Revenue Transactions
            </h3>
            
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="border-b border-white/10">
                        <tr>
                            <th class="px-4 py-3 text-left font-semibold">Date</th>
                            <th class="px-4 py-3 text-left font-semibold">Source</th>
                            <th class="px-4 py-3 text-left font-semibold">Type</th>
                            <th class="px-4 py-3 text-right font-semibold">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                        <tr class="hover:bg-white/5 transition">
                            <td colspan="4" class="px-4 py-8 text-center text-white/40">
                                <i class="fas fa-receipt text-3xl mb-2 block"></i>
                                No transactions yet. Start uploading content to earn!
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Withdrawal History -->
        <div class="card p-6 rounded-lg">
            <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                <i class="fas fa-arrow-down-to-bracket text-purple-400"></i> Withdrawal History
            </h3>
            
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="border-b border-white/10">
                        <tr>
                            <th class="px-4 py-3 text-left font-semibold">Date Requested</th>
                            <th class="px-4 py-3 text-left font-semibold">Amount</th>
                            <th class="px-4 py-3 text-left font-semibold">Method</th>
                            <th class="px-4 py-3 text-left font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                        <tr class="hover:bg-white/5 transition">
                            <td colspan="4" class="px-4 py-8 text-center text-white/40">
                                <i class="fas fa-history text-3xl mb-2 block"></i>
                                No withdrawal requests yet
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        function logout() {
            fetch('/api/auth/logout', { method: 'POST' })
                .then(() => { window.location.href = '/'; })
                .catch(err => { console.error('Logout error:', err); window.location.href = '/'; });
        }
    </script>
</body>
</html>
