<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shorts Insights - EchoVault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/pub/all.min.css">
    <style>
        body { background-color: #0a0a0a; color: white; }
        .sidebar { background-color: #121212; border-right: 1px solid #222; }
        .insight-table { border-collapse: separate; border-spacing: 0 8px; }
        .insight-row { background-color: #1a1a1a; transition: transform 0.2s; }
        .insight-row:hover { transform: scale(1.005); background-color: #222; }
    </style>
</head>
<body class="flex h-screen">
    <!-- Sidebar (Same as Dashboard) -->
    <div class="sidebar w-64 flex-shrink-0 flex flex-col">
        <div class="p-6 text-2xl font-bold text-purple-500">EchoVault</div>
        <nav class="flex-1 px-4 space-y-2">
            <a href="/api/artist/dashboard" class="flex items-center p-3 text-gray-400 hover:text-white rounded-lg"><i class="fas fa-home mr-3 w-5"></i> Dashboard</a>
            <a href="/api/artist/my-music" class="flex items-center p-3 text-gray-400 hover:text-white rounded-lg"><i class="fas fa-music mr-3 w-5"></i> My Music</a>
            <a href="/api/artist/shorts-insights" class="flex items-center p-3 text-white bg-purple-500/10 border-l-4 border-purple-500 rounded-r-lg"><i class="fas fa-chart-line mr-3 w-5 text-purple-500"></i> Shorts Insights</a>
            <a href="/api/artist/revenue" class="flex items-center p-3 text-gray-400 hover:text-white rounded-lg"><i class="fas fa-wallet mr-3 w-5"></i> Revenue</a>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-1 overflow-y-auto p-8">
        <div class="mb-8">
            <h1 class="text-3xl font-bold">Shorts Performance</h1>
            <p class="text-gray-400">Analyze how your vertical content is engaging your audience.</p>
        </div>

        <!-- Insights Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-gradient-to-br from-purple-900/20 to-black p-6 rounded-2xl border border-purple-500/20">
                <p class="text-gray-400 text-sm mb-1">Avg. Retention</p>
                <h3 class="text-2xl font-bold text-purple-400">68%</h3>
            </div>
            <div class="bg-gradient-to-br from-blue-900/20 to-black p-6 rounded-2xl border border-blue-500/20">
                <p class="text-gray-400 text-sm mb-1">Total Likes</p>
                <h3 class="text-2xl font-bold text-blue-400"><%= totalLikes || 0 %></h3>
            </div>
            <div class="bg-gradient-to-br from-pink-900/20 to-black p-6 rounded-2xl border border-pink-500/20">
                <p class="text-gray-400 text-sm mb-1">Gift Revenue</p>
                <h3 class="text-2xl font-bold text-pink-400">$<%= totalGiftRevenue || '0.00' %></h3>
            </div>
        </div>

        <!-- Shorts Table -->
        <div class="overflow-x-auto">
            <table class="w-full insight-table">
                <thead>
                    <tr class="text-left text-gray-500 text-sm uppercase">
                        <th class="px-6 py-4">Short Title</th>
                        <th class="px-6 py-4">Views</th>
                        <th class="px-6 py-4">Likes</th>
                        <th class="px-6 py-4">Gifts</th>
                        <th class="px-6 py-4">Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (shorts && shorts.length > 0) { %>
                        <% shorts.forEach(short => { %>
                            <tr class="insight-row text-sm">
                                <td class="px-6 py-4 rounded-l-xl flex items-center">
                                    <div class="w-10 h-10 bg-gray-800 rounded mr-3"></div>
                                    <span class="font-medium"><%= short.title %></span>
                                </td>
                                <td class="px-6 py-4 text-gray-300"><%= short.playCount.toLocaleString() %></td>
                                <td class="px-6 py-4 text-gray-300"><%= short.likes || 0 %></td>
                                <td class="px-6 py-4 text-pink-400"><%= short.giftsReceived || 0 %></td>
                                <td class="px-6 py-4 text-green-400 font-bold rounded-r-xl">
                                    $<%= (short.giftsReceived * 0.05).toFixed(2) %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                                No shorts found. Upload vertical clips to see analytics.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>