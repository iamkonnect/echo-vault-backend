<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Artist - EchoVault Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { 
            background: linear-gradient(135deg, #0F0C29 0%, #302B63 50%, #24243E 100%); 
            color: white; 
            font-family: 'Inter', sans-serif; 
        }
        .glass { 
            background: rgba(255, 255, 255, 0.03); 
            backdrop-filter: blur(15px); 
            border: 1px solid rgba(255,255,255,0.05); 
            border-radius: 1rem; 
        }
        .admin-sidebar { 
            background: rgba(15, 12, 41, 0.8); 
            backdrop-filter: blur(10px); 
            height: 100vh;
            position: sticky;
            top: 0;
        }
        input, select { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 12px 16px; border-radius: 8px; width: 100%; outline: none; transition: all 0.3s; }
        input:focus, select:focus { border-color: #8b5cf6; box-shadow: 0 0 20px rgba(139,92,246,0.15); }
        label { display: block; margin-bottom: 8px; color: #ccc; font-size: 14px; font-weight: 600; }
        .btn-primary { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; border: none; padding: 12px 24px; border-radius: 8px; font-weight: bold; cursor: pointer; transition: all 0.3s; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(139,92,246,0.3); }
        .btn-danger { background: rgba(239,68,68,0.2); color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); padding: 8px 16px; border-radius: 6px; cursor: pointer; transition: all 0.3s; }
        .btn-danger:hover { background: rgba(239,68,68,0.3); }
        .btn-success { background: rgba(16,185,129,0.2); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3); padding: 8px 16px; border-radius: 6px; cursor: pointer; transition: all 0.3s; }
        .btn-success:hover { background: rgba(16,185,129,0.3); }
        .toast { position: fixed; top: 20px; right: 20px; padding: 16px 24px; border-radius: 12px; font-weight: bold; z-index: 1000; animation: slideIn 0.3s ease; }
        .toast-success { background: rgba(16,185,129,0.9); color: white; border: 1px solid rgba(16,185,129,0.5); }
        .toast-error { background: rgba(239,68,68,0.9); color: white; border: 1px solid rgba(239,68,68,0.5); }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .role-badge { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: bold; }
        .role-active { background: rgba(16,185,129,0.2); color: #6ee7b7; }
        .role-suspended { background: rgba(239,68,68,0.2); color: #fca5a5; }
    </style>
</head>
<body class="flex min-h-screen">
    <aside class="w-72 admin-sidebar p-8 border-r border-white/5 flex flex-col justify-between">
        <div>
            <div class="flex items-center gap-3 mb-12 pb-8 border-b border-white/10">
                <div class="bg-gradient-to-br from-emerald-500 to-teal-500 p-3 rounded-xl shadow-lg">
                    <i class="fas fa-shield-alt text-white text-xl"></i>
                </div>
                <span class="font-black tracking-tight text-xl bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent">ADMIN CENTRAL</span>
            </div>
            <nav class="space-y-2">
                <div class="text-xs text-white/30 uppercase tracking-wider mb-4 font-medium">Overview</div>
                <a href="/api/admin/dashboard" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-chart-line w-5"></i> Dashboard
                </a>
                
                <div class="text-xs text-white/30 uppercase tracking-wider mt-8 mb-4 font-medium">User Management</div>
                <a href="/api/admin/users" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-users w-5"></i> User Directory
                </a>
                <a href="/api/admin/add-artist" class="flex items-center gap-3 p-3 rounded-xl bg-purple-500/10 border border-purple-500/30 text-purple-300 font-medium">
                    <i class="fas fa-microphone w-5"></i> Add Artist
                </a>
                <a href="/api/admin/artist-verification" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-check-circle w-5"></i> Artist Verification
                </a>
                <a href="/api/admin/create-admin" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-user-plus w-5"></i> Add Admin
                </a>
                
                <div class="text-xs text-white/30 uppercase tracking-wider mt-8 mb-4 font-medium">Content</div>
                <a href="/api/admin/music-management" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-music w-5"></i> Music
                </a>
                <a href="/api/admin/shorts-management" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-film w-5"></i> Shorts
                </a>
                
                <div class="text-xs text-white/30 uppercase tracking-wider mt-8 mb-4 font-medium">Finance</div>
                <a href="/api/admin/payouts" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-coins w-5"></i> Payouts
                </a>
                <a href="/api/admin/gifts" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-gift w-5"></i> Gift Management
                </a>
                
                <div class="text-xs text-white/30 uppercase tracking-wider mt-8 mb-4 font-medium">Reports</div>
                <a href="/api/admin/reports" class="flex items-center gap-3 p-3 rounded-xl text-white/70 hover:text-white hover:bg-white/5 transition-all">
                    <i class="fas fa-flag w-5"></i> Reports
                </a>
            </nav>
        </div>
        <button onclick="logout()" class="w-full flex items-center justify-center gap-2 p-3 bg-red-600/20 text-red-400 hover:bg-red-600/30 rounded-lg transition border border-red-600/30">
            <i class="fas fa-sign-out-alt"></i> Logout
        </button>
    </aside>

    <main class="flex-1 p-12 overflow-y-auto">
        <div class="mb-12">
            <h1 class="text-5xl font-black bg-gradient-to-r from-purple-400 via-pink-400 to-purple-600 bg-clip-text text-transparent tracking-tight mb-2">Artist Management</h1>
            <p class="text-white/60 text-lg">Create, edit, or suspend artist accounts. Credentials are emailed automatically.</p>
        </div>

        <!-- Add Artist Form -->
        <div class="glass p-8 mb-12 max-w-2xl">
            <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
                <i class="fas fa-user-plus text-purple-400"></i> Add New Artist
            </h2>
            <form id="addArtistForm" onsubmit="return addArtist(event)" class="space-y-6">
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label for="name">Full Name <span class="text-red-400">*</span></label>
                        <input type="text" id="name" name="name" required placeholder="e.g. John Doe">
                    </div>
                    <div>
                        <label for="username">Username <span class="text-red-400">*</span></label>
                        <input type="text" id="username" name="username" required placeholder="e.g. johndoe">
                    </div>
                <div>
                    <label for="email">Email Address <span class="text-red-400">*</span></label>
                    <input type="email" id="email" name="email" required placeholder="artist@example.com">
                    <p class="text-white/40 text-xs mt-1">Login credentials will be sent to this email</p>
                </div>
                <div>
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" placeholder="+255 712 345 678">
                </div>
                <div class="flex items-center gap-4">
                    <div class="flex-1">
                        <label for="genre">Primary Genre</label>
                        <select id="genre" name="genre">
                            <option value="">Select genre...</option>
                            <option value="Afro Jazz">Afro Jazz</option>
                            <option value="Amapiano">Amapiano</option>
                            <option value="Bongo Flavour">Bongo Flavour</option>
                            <option value="Genge">Genge</option>
                            <option value="Dancehall">Dancehall</option>
                            <option value="Reggae">Reggae</option>
                            <option value="Hip Hop">Hip Hop</option>
                            <option value="RnB">RnB</option>
                            <option value="Soul Music">Soul Music</option>
                            <option value="Taarab">Taarab</option>
                            <option value="Zouk">Zouk</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="flex-1">
                        <label for="country">Country</label>
                        <input type="text" id="country" name="country" placeholder="e.g. Tanzania">
                    </div>
                <div>
                    <label class="flex items-center gap-3">
                        <input type="checkbox" id="sendEmail" checked class="w-5 h-5 accent-purple-500">
                        <span class="text-white/80">Send login credentials via email</span>
                    </label>
                </div>
                <button type="submit" id="submitBtn" class="btn-primary w-full text-lg py-4">
                    <i class="fas fa-microphone mr-2"></i> Create Artist Account
                </button>
            </form>
            <div id="formResult" class="mt-4 hidden"></div>

        <!-- Existing Artists List -->
        <div class="glass p-8">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold flex items-center gap-3">
                    <i class="fas fa-list text-purple-400"></i> All Artists
                </h2>
                <div class="flex gap-2">
                    <input type="text" id="searchArtist" placeholder="Search artists..." class="w-64" onkeyup="filterArtists()">
                </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-white/5 text-white/40 text-sm uppercase">
                        <tr>
                            <th class="p-4">Artist</th>
                            <th class="p-4">Contact</th>
                            <th class="p-4">Status</th>
                            <th class="p-4">Content</th>
                            <th class="p-4">Joined</th>
                            <th class="p-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="artistsTableBody" class="divide-y divide-white/5">
                        <tr>
                            <td colspan="6" class="p-8 text-center text-white/40">
                                <i class="fas fa-spinner fa-spin text-2xl mb-2"></i>
                                <p>Loading artists...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
    </main>

    <script>
        // Load artists on page load
        document.addEventListener('DOMContentLoaded', loadArtists);

        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            toast.innerHTML = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }

        async function loadArtists() {
            try {
                const res = await fetch('/api/admin/artists/api');
                const artists = await res.json();
                renderArtists(artists);
            } catch (e) {
                document.getElementById('artistsTableBody').innerHTML = 
                    '<tr><td colspan="6" class="p-8 text-center text-white/40">Failed to load artists</td></tr>';
            }
        }

        function renderArtists(artists) {
            const tbody = document.getElementById('artistsTableBody');
            if (!artists || artists.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-white/40">No artists found</td></tr>';
                return;
            }
            tbody.innerHTML = artists.map(artist => `
                <tr class="artist-row hover:bg-white/5 transition">
                    <td class="p-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center font-bold text-sm">
                                ${artist.name ? artist.name.charAt(0).toUpperCase() : '?'}
                            </div>
                            <div>
                                <p class="font-semibold text-white">${artist.name || 'Unknown'}</p>
                                <p class="text-sm text-white/50">@${artist.username || 'N/A'}</p>
                            </div>
                    </td>
                    <td class="p-4">
                        <p class="text-white/80 text-sm">${artist.email || 'N/A'}</p>
                        <p class="text-white/40 text-xs">${artist.phone || ''}</p>
                    </td>
                    <td class="p-4">
                        <span class="role-badge ${artist.isSuspended ? 'role-suspended' : 'role-active'}">
                            ${artist.isSuspended ? 'Suspended' : 'Active'}
                        </span>
                        ${artist.isVerified ? '<span class="role-badge role-active ml-1">Verified</span>' : ''}
                    </td>
                    <td class="p-4 text-white/70 text-sm">
                        ${artist._count?.songs || 0} songs &bull; ${artist._count?.shorts || 0} shorts
                    </td>
                    <td class="p-4 text-white/50 text-sm">
                        ${artist.createdAt ? new Date(artist.createdAt).toLocaleDateString() : 'N/A'}
                    </td>
                    <td class="p-4">
                        <div class="flex gap-2">
                            ${artist.isSuspended ? 
                                `<button onclick="unsuspendArtist('${artist.id}')" class="btn-success text-xs"><i class="fas fa-undo"></i> Unsuspend</button>` :
                                `<button onclick="suspendArtist('${artist.id}')" class="btn-danger text-xs"><i class="fas fa-ban"></i> Suspend</button>`
                            }
                            <button onclick="resendCredentials('${artist.id}')" class="text-purple-400 hover:text-purple-300 text-xs font-semibold">
                                <i class="fas fa-envelope"></i> Resend
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function filterArtists() {
            const query = document.getElementById('searchArtist').value.toLowerCase();
            document.querySelectorAll('.artist-row').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(query) ? '' : 'none';
            });
        }

        async function addArtist(event) {
            event.preventDefault();
            const form = document.getElementById('addArtistForm');
            const btn = document.getElementById('submitBtn');
            const resultDiv = document.getElementById('formResult');
            
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Creating artist...';
            resultDiv.classList.add('hidden');

            try {
                const res = await fetch('/api/admin/artists/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();

                if (result.success) {
                    showToast(`Artist "${result.data.name}" created! Credentials sent to ${result.data.email}`, 'success');
                    form.reset();
                    loadArtists();
                } else {
                    showToast(result.error || 'Failed to create artist', 'error');
                }
            } catch (e) {
                showToast('Network error: ' + e.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-microphone mr-2"></i> Create Artist Account';
            }
        }

        async function suspendArtist(id) {
            if (!confirm('Are you sure you want to suspend this artist?')) return;
            try {
                const res = await fetch(`/api/admin/artists/${id}/suspend`, { method: 'POST' });
                const result = await res.json();
                if (result.success) {
                    showToast('Artist suspended successfully');
                    loadArtists();
                } else {
                    showToast(result.error || 'Failed to suspend', 'error');
                }
            } catch (e) {
                showToast('Error: ' + e.message, 'error');
            }
        }

        async function unsuspendArtist(id) {
            try {
                const res = await fetch(`/api/admin/artists/${id}/unsuspend`, { method: 'POST' });
                const result = await res.json();
                if (result.success) {
                    showToast('Artist reactivated');
                    loadArtists();
                } else {
                    showToast(result.error || 'Failed to unsuspend', 'error');
                }
            } catch (e) {
                showToast('Error: ' + e.message, 'error');
            }
        }

        async function resendCredentials(id) {
            try {
                const res = await fetch(`/api/admin/artists/${id}/resend-credentials`, { method: 'POST' });
                const result = await res.json();
                if (result.success) {
                    showToast('Credentials resent to email');
                } else {
                    showToast(result.error || 'Failed to resend', 'error');
                }
            } catch (e) {
                showToast('Error: ' + e.message, 'error');
            }
        }

        function logout() {
            if (confirm('Are you sure you want to logout?')) {
                fetch('/api/auth/logout', { method: 'POST' })
                    .then(() => window.location.href = '/')
                    .catch(() => window.location.href = '/');
            }
        }
    </script>
</body>
</html>
</create_file>
