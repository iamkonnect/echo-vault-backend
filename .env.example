# EchoVault Backend - Environment Variables Reference
# This file shows all available environment variables

# ============ SERVER CONFIGURATION ============
PORT=5000
NODE_ENV=development

# ============ DATABASE ============
# Local development example:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/echo_vault_db?schema=public

# Azure production example:
# DATABASE_URL=postgresql://echovaultadmin:YourPassword@echovault-db.postgres.database.azure.com:5432/echo_vault_db?schema=public&sslmode=require

DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/echo_vault_db?schema=public

# ============ AUTHENTICATION ============
JWT_SECRET=echovault_supersecret2024_CHANGE_IN_PRODUCTION

# ============ CORS & FRONTEND ============
# URLs where your frontend is hosted
# Multiple values separated by commas for local development
CLIENT_URL=http://localhost:3000

# For production Azure deployment:
# CLIENT_URL=https://echovault-web.azureapp.com

# ============ OPTIONAL: PAYMENT GATEWAY ============
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...

# ============ OPTIONAL: EMAIL SERVICE ============
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@echovault.com

# ============ OPTIONAL: FILE STORAGE ============
# AWS_S3_BUCKET=echovault-bucket
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Or Azure Blob Storage:
# AZURE_STORAGE_ACCOUNT_NAME=echovaultstorage
# AZURE_STORAGE_ACCOUNT_KEY=...
# AZURE_STORAGE_CONTAINER=music-files

# ============ OPTIONAL: LOGGING ============
# LOG_LEVEL=debug|info|warn|error
# LOG_FILE=/var/log/echovault/app.log

# ============ OPTIONAL: REDIS CACHE ============
# REDIS_URL=redis://localhost:6379

# ============ OPTIONAL: MONITORING ============
# SENTRY_DSN=...
# NEW_RELIC_LICENSE_KEY=...

# ============ NOTES FOR DEPLOYMENT ============
# - LOCAL: All localhost URLs, no SSL required
# - DEVELOPMENT: Can use 10.0.2.2 for Android emulator
# - STAGING: Use staging Azure URLs
# - PRODUCTION: Use production Azure URLs, enable SSL mode
#
# SECURITY:
# - NEVER commit real credentials to git
# - Use .gitignore to exclude .env files
# - Use Azure Key Vault for production secrets
# - Rotate JWT_SECRET regularly
# - Use strong random passwords for DATABASE_URL
