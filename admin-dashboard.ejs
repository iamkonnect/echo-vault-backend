    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.min.js"></script>
    <script>
        let currentDateRange = { startDate: new Date(new Date().setMonth(new Date().getMonth() - 1)), endDate: new Date() };

        function toggleDateDropdown() {
            const dropdown = document.getElementById('dateDropdown');
            const chevron = document.getElementById('dateChevron');
            dropdown.classList.toggle('hidden');
            if (!dropdown.classList.contains('hidden')) {
                chevron.style.transform = 'rotate(180deg)';
            } else {
                chevron.style.transform = 'rotate(0deg)';
            }
        }

        function setDateRange(range) {
            const today = new Date();
            let startDate = new Date();
            let rangeLabel = '';

            switch (range) {
                case '1month':
                    startDate = new Date(today.getFullYear(), today.getMonth() - 1, today.getDate());
                    rangeLabel = 'Last 1 Month';
                    break;
                case '3months':
                    startDate = new Date(today.getFullYear(), today.getMonth() - 3, today.getDate());
                    rangeLabel = 'Last 3 Months';
                    break;
                case '6months':
                    startDate = new Date(today.getFullYear(), today.getMonth() - 6, today.getDate());
                    rangeLabel = 'Last 6 Months';
                    break;
                case '9months':
                    startDate = new Date(today.getFullYear(), today.getMonth() - 9, today.getDate());
                    rangeLabel = 'Last 9 Months';
                    break;
                case '1year':
                    startDate = new Date(today.getFullYear() - 1, today.getMonth(), today.getDate());
                    rangeLabel = 'Last 1 Year';
                    break;
            }

            currentDateRange = { startDate, endDate: today };
            document.getElementById('dateRangeDisplay').textContent = rangeLabel;
            document.getElementById('dateDropdown').classList.add('hidden');
            document.getElementById('dateChevron').style.transform = 'rotate(0deg)';
            loadAnalyticsData(startDate, today);
        }

        function applyCustomRange() {
            const startDateStr = document.getElementById('customStartDate').value;
            const endDateStr = document.getElementById('customEndDate').value;

            if (!startDateStr || !endDateStr) {
                alert('Please select both start and end dates');
                return;
            }

            const startDate = new Date(startDateStr);
            const endDate = new Date(endDateStr);

            if (startDate > endDate) {
                alert('Start date must be before end date');
                return;
            }

            currentDateRange = { startDate, endDate };
            const rangeLabel = `${startDate.toLocaleDateString()} - ${endDate.toLocaleDateString()}`;
            document.getElementById('dateRangeDisplay').textContent = rangeLabel;
            document.getElementById('dateDropdown').classList.add('hidden');
            document.getElementById('dateChevron').style.transform = 'rotate(0deg)';
            loadAnalyticsData(startDate, endDate);
        }

        function toggleExportMenu() {
            const menu = document.getElementById('exportMenu');
            const chevron = document.getElementById('exportChevron');
            menu.classList.toggle('hidden');
            if (!menu.classList.contains('hidden')) {
                chevron.style.transform = 'rotate(180deg)';
            } else {
                chevron.style.transform = 'rotate(0deg)';
            }
        }

        function exportPDF() {
            const element = document.querySelector('main');
            const opt = {
                margin: 10,
                filename: `EchoVault_Analytics_${new Date().getTime()}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { orientation: 'landscape', unit: 'mm', format: 'a4' }
            };
            html2pdf().set(opt).from(element).save();
            toggleExportMenu();
        }

        function exportCSV() {
            alert('CSV export feature is ready for backend integration');
            toggleExportMenu();
        }

        function exportXML() {
            alert('XML export feature is ready for backend integration');
            toggleExportMenu();
        }

        function loadAnalyticsData(startDate, endDate) {
            console.log(`Loading analytics from ${startDate.toISOString()} to ${endDate.toISOString()}`);
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('dateRangeDisplay').textContent = 'Last 1 Month';
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('customEndDate').value = today;
            const lastMonth = new Date();
            lastMonth.setMonth(lastMonth.getMonth() - 1);
            document.getElementById('customStartDate').value = lastMonth.toISOString().split('T')[0];
        });

        function logout() {
            fetch('/api/auth/logout', { method: 'POST' })
                .then(() => { window.location.href = '/'; })
                .catch(err => { console.error('Logout error:', err); window.location.href = '/'; });
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(event) {
            const dateDropdown = document.getElementById('dateDropdown');
            const dateBtn = event.target.closest('button[onclick*="toggleDate"]');
            const exportDropdown = document.getElementById('exportMenu');
            const exportBtn = event.target.closest('button[onclick*="toggleExport"]');
            
            if (!dateBtn && !dateDropdown.contains(event.target) && !dateDropdown.classList.contains('hidden')) {
                dateDropdown.classList.add('hidden');
                document.getElementById('dateChevron').style.transform = 'rotate(0deg)';
            }
            
            if (!exportBtn && !exportDropdown.contains(event.target) && !exportDropdown.classList.contains('hidden')) {
                exportDropdown.classList.add('hidden');
                document.getElementById('exportChevron').style.transform = 'rotate(0deg)';
            }
        });
    </script>
</body>
</html>
