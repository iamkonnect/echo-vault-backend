<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>EchoVault Admin Central</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <style>
        body { background: linear-gradient(135deg, #0F0C29 0%, #302B63 50%, #24243E 100%); color: white; font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.05); border-radius: 1rem; }
        .admin-sidebar { background: rgba(15,12,41,0.8); backdrop-filter: blur(10px); }
        .dropdown-active { display: block !important; }
        .chart-container { position: relative; width: 100%; height: 100%; }
    </style>
</head>
<body class="flex min-h-screen">
    <aside class="w-72 admin-sidebar p-8 border-r border-white/5 shadow-2xl flex flex-col justify-between">
        <div>
            <div class="flex items-center gap-3 mb-12 pb-8 border-b border-white/10">
                <div class="bg-gradient-to-br from-emerald-500 to-teal-500 p-3 rounded-xl shadow-lg">
                    <i class="fas fa-shield-alt text-white text-xl"></i>
                </div>
                <span class="font-black tracking-tight text-xl bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent">ADMIN CENTRAL</span>
            </div>
            <nav class="space-y-2">
                <div class="text-xs text-white/30 uppercase tracking-wider mb-4 font-medium">Overview</div>
                <a href="#" class="flex items-center gap-3 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 font-medium">
                    <i class="fas fa-chart-line w-5"></i><span>Dashboard</span>
                </a>
                <a href="/api/admin/users" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-users w-5"></i> User Directory
                </a>
                <div class="text-xs text-white/30 uppercase tracking-wider mt-8 mb-4 font-medium">Management</div>
                <a href="/api/admin/artist-verification" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-microphone w-5"></i> Artist Verification
                </a>
                <a href="/api/admin/create-admin" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-user-plus w-5"></i> Add Admin
                </a>
                <a href="/api/admin/payouts" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-coins w-5"></i> Payouts
                </a>
                <a href="/api/admin/gifts" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-gift w-5"></i> Gift Management
                </a>
                <a href="/api/admin/reports" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-flag w-5"></i> Reports
                </a>
            </nav>
        </div>
        <button onclick="logout()" class="w-full flex items-center justify-center gap-2 p-3 bg-red-600/20 text-red-400 hover:bg-red-600/30 rounded-lg transition border border-red-600/30">
            <i class="fas fa-sign-out-alt"></i> Logout
        </button>
    </aside>

    <main class="flex-1 p-12 overflow-y-auto">
        <header class="flex justify-between items-center mb-16 pb-8 border-b border-white/10">
            <div>
                <h1 class="text-5xl font-black bg-gradient-to-r from-emerald-400 via-teal-400 to-emerald-600 bg-clip-text text-transparent tracking-tight mb-2">Platform Control</h1>
                <p class="text-xl text-white/60 font-light">Welcome, <%= user.name %> - <%= user.role === 'ADMIN' ? 'Super Admin' : 'Staff' %></p>
            </div>
            <div class="glass p-6 min-w-[200px] text-center">
                <p class="text-xs text-emerald-400 uppercase font-bold tracking-wider mb-1">Platform Revenue</p>
                <p class="text-3xl font-mono font-bold text-emerald-300">$<%= Math.round((stats.revenue || 0) * 100) / 100 %></p>
            </div>
        </header>

        <!-- Key Metrics -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            <div class="glass p-8 border border-emerald-500/20 hover:border-emerald-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-emerald-500/20 rounded-xl"><i class="fas fa-users text-emerald-400"></i></span>
                    <span class="text-emerald-400 text-sm font-bold">0%</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">Total Users</p>
                <p class="text-4xl font-black"><%= stats.userCount || 0 %></p>
            </div>
            <div class="glass p-8 border border-blue-500/20 hover:border-blue-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-blue-500/20 rounded-xl"><i class="fas fa-microphone text-blue-400"></i></span>
                    <span class="text-emerald-400 text-sm font-bold">0%</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">Active Artists</p>
                <p class="text-4xl font-black"><%= stats.artistCount || 0 %></p>
            </div>
            <div class="glass p-8 border border-orange-500/20 hover:border-orange-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-orange-500/20 rounded-xl"><i class="fas fa-clock text-orange-400"></i></span>
                    <span class="text-orange-400 text-sm font-bold">0</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">Pending Payouts</p>
                <p class="text-4xl font-black"><%= stats.withdrawals ? stats.withdrawals.length : 0 %></p>
            </div>
            <div class="glass p-8 border border-purple-500/20 hover:border-purple-400/40 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="p-2 bg-purple-500/20 rounded-xl"><i class="fas fa-flag text-purple-400"></i></span>
                    <span class="text-red-400 text-sm font-bold">0</span>
                </div>
                <p class="text-sm text-white/50 mb-2 uppercase tracking-wide">Active Reports</p>
                <p class="text-4xl font-black"><%= stats.reportsCount || 0 %></p>
            </div>
        </div>

        <!-- Quick Actions & Recent Users -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
            <div class="lg:col-span-1 glass p-8">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                    <i class="fas fa-bolt"></i> Quick Actions
                </h3>
                <div class="space-y-3">
                    <a href="/api/admin/users" class="block p-4 bg-white/5 rounded-xl hover:bg-white/10 transition-all text-left">
                        <div class="flex items-center gap-3 mb-1">
                            <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                                <i class="fas fa-search text-blue-400"></i>
                            </div>
                            <div>
                                <p class="font-medium text-white">User Directory</p>
                                <p class="text-sm text-white/50">View all accounts</p>
                            </div>
                        </div>
                    </a>
                    <a href="/api/admin/create-admin" class="block p-4 bg-white/5 rounded-xl hover:bg-white/10 transition-all text-left">
                        <div class="flex items-center gap-3 mb-1">
                            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
                                <i class="fas fa-user-plus text-emerald-400"></i>
                            </div>
                            <div>
                                <p class="font-medium text-white">Add Admin</p>
                                <p class="text-sm text-white/50">Grant admin access</p>
                            </div>
                        </div>
                    </a>
                    <a href="/api/admin/payouts" class="block p-4 bg-white/5 rounded-xl hover:bg-white/10 transition-all text-left">
                        <div class="flex items-center gap-3 mb-1">
                            <div class="w-10 h-10 bg-orange-500/20 rounded-lg flex items-center justify-center">
                                <i class="fas fa-coins text-orange-400"></i>
                            </div>
                            <div>
                                <p class="font-medium text-white">Review Payouts</p>
                                <p class="text-sm text-white/50">Approve withdrawals</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <div class="lg:col-span-2 glass p-8">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                    <i class="fas fa-list"></i> Recent Withdrawals
                </h3>
                <div class="space-y-4">
                    <% if (!stats.withdrawals || stats.withdrawals.length === 0) { %>
                        <p class="text-white/40 text-center py-12">No pending withdrawals.</p>
                    <% } else { %>
                        <% stats.withdrawals.slice(0, 5).forEach(w => { %>
                            <div class="flex items-center gap-4 p-4 bg-white/5 rounded-xl hover:bg-white/10 transition-all">
                                <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-purple-500 rounded-xl flex items-center justify-center text-white font-bold text-sm"><%= w.user ? w.user.name.charAt(0).toUpperCase() : '?' %></div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-medium text-white truncate"><%= w.user ? w.user.name : 'Unknown' %></p>
                                    <p class="text-sm text-white/50"><%= w.user ? w.user.email : 'N/A' %></p>
                                </div>
                                <div class="text-right">
                                    <p class="font-mono text-lg font-bold text-emerald-400">$<%= w.amount %></p>
                                    <p class="text-xs text-orange-400">Pending</p>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Platform Analytics -->
        <div class="glass p-12 border border-emerald-500/20">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h2 class="text-3xl font-black bg-gradient-to-r from-emerald-400 via-teal-400 to-emerald-600 bg-clip-text text-transparent mb-2 flex items-center gap-3">
                        <i class="fas fa-chart-line text-emerald-400"></i> Platform Analytics
                    </h2>
                    <p class="text-white/60">Real-time insights into platform performance and revenue streams</p>
                </div>
                <div class="flex gap-3">
                    <!-- Date Range Selector -->
                    <div class="relative" style="z-index: 50;">
                        <button onclick="toggleDateDropdown()" class="glass px-4 py-2 rounded-lg border border-white/20 hover:border-white/40 text-white/80 hover:text-white transition flex items-center gap-2 whitespace-nowrap">
                            <i class="fas fa-calendar"></i>
                            <span id="dateRangeDisplay">Last 1 Month</span>
                            <i class="fas fa-chevron-down" id="dateChevron" style="transition: transform 0.3s;"></i>
                        </button>
                        <div id="dateDropdown" class="hidden absolute right-0 mt-2 w-56 glass border border-white/20 rounded-lg shadow-2xl" style="z-index: 100;">
                            <div class="p-4 space-y-2 max-h-96 overflow-y-auto">
                                <button onclick="setDateRange('1month'); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition">Last 1 Month</button>
                                <button onclick="setDateRange('3months'); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition">Last 3 Months</button>
                                <button onclick="setDateRange('6months'); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition">Last 6 Months</button>
                                <button onclick="setDateRange('9months'); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition">Last 9 Months</button>
                                <button onclick="setDateRange('1year'); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition">Last 1 Year</button>
                                <div class="border-t border-white/10 my-2"></div>
                                <div class="px-3 py-2">
                                    <p class="text-white/60 text-xs mb-2">Custom Range:</p>
                                    <input type="date" id="customStartDate" class="w-full bg-white/10 border border-white/20 rounded px-2 py-1 text-white/80 text-sm mb-1">
                                    <input type="date" id="customEndDate" class="w-full bg-white/10 border border-white/20 rounded px-2 py-1 text-white/80 text-sm mb-2">
                                    <button onclick="applyCustomRange(); return false;" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white px-2 py-1 rounded text-sm transition">Apply</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Export Dropdown -->
                    <div class="relative" style="z-index: 50;">
                        <button onclick="toggleExportMenu()" class="glass px-4 py-2 rounded-lg border border-white/20 hover:border-white/40 text-white/80 hover:text-white transition flex items-center gap-2 bg-emerald-500/10 whitespace-nowrap">
                            <i class="fas fa-download"></i>
                            <span>Export</span>
                            <i class="fas fa-chevron-down" id="exportChevron" style="transition: transform 0.3s;"></i>
                        </button>
                        <div id="exportMenu" class="hidden absolute right-0 mt-2 w-48 glass border border-white/20 rounded-lg shadow-2xl" style="z-index: 100;">
                            <div class="p-2">
                                <button onclick="exportPDF(); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition flex items-center gap-2">
                                    <i class="fas fa-file-pdf text-red-400"></i> Export as PDF
                                </button>
                                <button onclick="exportCSV(); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition flex items-center gap-2">
                                    <i class="fas fa-file-csv text-green-400"></i> Export as CSV
                                </button>
                                <button onclick="exportXML(); return false;" class="w-full text-left px-3 py-2 rounded hover:bg-white/10 text-white/80 hover:text-white transition flex items-center gap-2">
                                    <i class="fas fa-file-code text-blue-400"></i> Export as XML
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts Section (KEPT AS-IS - Demo data for visual display) -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <!-- Revenue Trend Chart -->
                <div class="glass p-8 border border-emerald-500/20 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500 via-teal-500 to-emerald-500"></div>
                    <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                        <i class="fas fa-chart-line text-emerald-400"></i> Revenue Trend
                    </h3>
                    <div class="relative h-80 bg-gradient-to-br from-slate-900/20 via-emerald-900/10 to-slate-900/20 rounded-2xl p-8 border border-emerald-500/20 overflow-hidden">
                        <div class="absolute inset-0 opacity-10">
                            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                                <defs>
                                    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                                        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#10b981" stroke-width="0.5"/>
                                    </pattern>
                                </defs>
                                <rect width="100%" height="100%" fill="url(#grid)" />
                            </svg>
                        </div>
                        <svg viewBox="0 0 600 280" preserveAspectRatio="xMidYMid meet" class="w-full h-full relative z-10">
                            <defs>
                                <linearGradient id="advTrendGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" style="stop-color:#10b981;stop-opacity:0.3" />
                                    <stop offset="50%" style="stop-color:#14b8a6;stop-opacity:0.15" />
                                    <stop offset="100%" style="stop-color:#10b981;stop-opacity:0.05" />
                                </linearGradient>
                                <filter id="glow">
                                    <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                                    <feMerge>
                                        <feMergeNode in="coloredBlur"/>
                                        <feMergeNode in="SourceGraphic"/>
                                    </feMerge>
                                </filter>
                            </defs>
                            <line x1="50" y1="200" x2="550" y2="200" stroke="#10b981" stroke-width="1" opacity="0.2"/>
                            <line x1="50" y1="150" x2="550" y2="150" stroke="#10b981" stroke-width="1" opacity="0.2"/>
                            <line x1="50" y1="100" x2="550" y2="100" stroke="#10b981" stroke-width="1" opacity="0.2"/>
                            <line x1="50" y1="50" x2="550" y2="50" stroke="#10b981" stroke-width="1" opacity="0.2"/>
                            <text x="40" y="205" font-size="12" fill="#9ca3af">$0</text>
                            <text x="30" y="155" font-size="12" fill="#9ca3af">$20K</text>
                            <text x="30" y="105" font-size="12" fill="#9ca3af">$40K</text>
                            <text x="30" y="55" font-size="12" fill="#9ca3af">$60K</text>
                            <polyline points="70,180 150,140 230,110 310,80 390,60 470,45 550,30" fill="none" stroke="url(#advTrendGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" filter="url(#glow)"/>
                            <polygon points="70,180 150,140 230,110 310,80 390,60 470,45 550,30 550,230 70,230" fill="url(#advTrendGradient)"/>
                            <circle cx="70" cy="180" r="5" fill="#10b981" opacity="0.8"/>
                            <circle cx="150" cy="140" r="5" fill="#10b981" opacity="0.8"/>
                            <circle cx="230" cy="110" r="5" fill="#10b981" opacity="0.8"/>
                            <circle cx="310" cy="80" r="5" fill="#10b981" opacity="0.8"/>
                            <circle cx="390" cy="60" r="5" fill="#10b981" opacity="0.8"/>
                            <circle cx="470" cy="45" r="5" fill="#14b8a6" opacity="0.9"/>
                            <circle cx="550" cy="30" r="6" fill="#14b8a6" opacity="1"/>
                            <text x="70" y="250" font-size="12" fill="#9ca3af" text-anchor="middle">W1</text>
                            <text x="150" y="250" font-size="12" fill="#9ca3af" text-anchor="middle">W2</text>
                            <text x="230" y="250" font-size="12" fill="#9ca3af" text-anchor="middle">W3</text>
                            <text x="310" y="250" font-size="12" fill="#9ca3af" text-anchor="middle">W4</text>
                            <text x="390" y="250" font-size="12" fill="#9ca3af" text-anchor="middle">W5</text>
                            <text x="470" y="250" font-size="12" fill="#9ca3af" text-anchor="middle">W6</text>
                            <text x="550" y="250" font-size="12" fill="#10b981" text-anchor="middle" font-weight="bold">W7</text>
                        </svg>
                    </div>
                    <div class="mt-4 flex items-center justify-center gap-4 text-sm">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full" style="background-color:#10b981"></div>
                            <span class="text-white/70">Weekly Revenue</span>
                        </div>
                    </div>
                </div>

                <!-- Revenue Distribution Chart -->
                <div class="glass p-8 border border-emerald-500/20 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-l from-emerald-500 via-teal-500 to-emerald-500"></div>
                    <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                        <i class="fas fa-pie-chart text-purple-400"></i> Revenue Distribution
                    </h3>
                    <div class="flex items-center justify-center h-80 relative">
                        <svg viewBox="0 0 200 200" class="w-72 h-72">
                            <defs>
                                <radialGradient id="centerGlow" cx="50%" cy="50%" r="50%">
                                    <stop offset="0%" style="stop-color:#1f2937;stop-opacity:1" />
                                    <stop offset="100%" style="stop-color:#0f0f0f;stop-opacity:1" />
                                </radialGradient>
                                <filter id="donutGlow">
                                    <feDropShadow dx="0" dy="0" stdDeviation="3" flood-opacity="0.4" flood-color="#10b981"/>
                                </filter>
                            </defs>
                            <circle cx="100" cy="100" r="80" fill="none" stroke="#3b82f6" stroke-width="28" stroke-dasharray="211,500" filter="url(#donutGlow)"/>
                            <circle cx="100" cy="100" r="80" fill="none" stroke="#8b5cf6" stroke-width="28" stroke-dasharray="143,500" stroke-dashoffset="-211" filter="url(#donutGlow)"/>
                            <circle cx="100" cy="100" r="80" fill="none" stroke="#f97316" stroke-width="28" stroke-dasharray="96,500" stroke-dashoffset="-354" filter="url(#donutGlow)"/>
                            <circle cx="100" cy="100" r="80" fill="none" stroke="#10b981" stroke-width="28" stroke-dasharray="50,500" stroke-dashoffset="-450" filter="url(#donutGlow)"/>
                            <circle cx="100" cy="100" r="50" fill="url(#centerGlow)"/>
                            <text x="100" y="100" font-size="32" font-weight="bold" fill="#ffffff" text-anchor="middle" dominant-baseline="middle">100%</text>
                            <text x="100" y="125" font-size="14" fill="#9ca3af" text-anchor="middle">Total Revenue</text>
                        </svg>
                    </div>
                    <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full" style="background-color:#3b82f6"></div>
                            <span class="text-white/70">Music</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full" style="background-color:#8b5cf6"></div>
                            <span class="text-white/70">Gifts</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full" style="background-color:#f97316"></div>
                            <span class="text-white/70">Live</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full" style="background-color:#10b981"></div>
                            <span class="text-white/70">Ads</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Top Artists Table - NOW USING REAL DATA FROM DATABASE -->
            <div class="glass p-8 border border-white/10 mb-8">
                <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                    <i class="fas fa-microphone text-pink-400"></i> Top Artists
                </h3>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-white/5 border-b border-white/10">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold text-white">#</th>
                                <th class="px-4 py-3 text-left font-semibold text-white">Artist Name</th>
                                <th class="px-4 py-3 text-left font-semibold text-white">Total Streams</th>
                                <th class="px-4 py-3 text-left font-semibold text-white">Followers</th>
