<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Video - Artist Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0a0a0a; color: white; }
        .sidebar { background-color: #121212; border-right: 1px solid #222; }
        .card { background-color: #1a1a1a; border: 1px solid #333; }
        .active-link { background-color: rgba(168, 85, 247, 0.1); border-left: 4px solid rgb(168, 85, 247); }
    </style>
</head>
<body class="flex h-screen">
    <!-- Sidebar -->
    <div class="sidebar w-64 flex-shrink-0 flex flex-col">
        <div class="p-6 text-2xl font-bold text-purple-500">
            <i class="fas fa-music mr-2"></i>EchoVault
        </div>
        
        <nav class="flex-1 px-4 space-y-2 py-6">
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-4 font-medium px-2">Navigation</div>
            
            <a href="/api/artist/dashboard" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-home mr-3 w-5"></i>
                <span>Dashboard</span>
            </a>
            
            <a href="/api/artist/my-music" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-compact-disc mr-3 w-5"></i>
                <span>My Music</span>
            </a>
            
            <a href="/api/artist/insights" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-chart-line mr-3 w-5"></i>
                <span>Insights</span>
            </a>
            
            <a href="/api/artist/revenue" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-wallet mr-3 w-5"></i>
                <span>Revenue</span>
            </a>
            
            <a href="/api/artist/live-insights" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-broadcast-tower mr-3 w-5"></i>
                <span>Live Insights</span>
            </a>

            <div class="text-xs text-gray-500 uppercase tracking-wider mt-8 mb-4 font-medium px-2">Upload</div>
            
            <a href="/api/artist/upload-song" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-music mr-3 w-5"></i>
                <span>Upload Song</span>
            </a>
            
            <a href="/api/artist/upload-video" class="flex items-center p-3 text-white active-link rounded-r-lg transition-all">
                <i class="fas fa-video mr-3 w-5"></i>
                <span>Upload Video</span>
            </a>
            
            <a href="/api/artist/upload-shorts" class="flex items-center p-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                <i class="fas fa-film mr-3 w-5"></i>
                <span>Upload Shorts</span>
            </a>
        </nav>

        <button onclick="logout()" class="m-4 w-[calc(100%-2rem)] flex items-center justify-center gap-2 p-3 bg-red-600/20 text-red-400 hover:bg-red-600/30 rounded-lg transition-all border border-red-600/30">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </button>
    </div>

    <!-- Main Content -->
    <div class="flex-1 overflow-y-auto p-8">
        <header class="mb-8 pb-6 border-b border-white/10">
            <h1 class="text-4xl font-bold text-purple-400 mb-2">Upload New Video</h1>
            <p class="text-gray-400">Share your video content with the world</p>
        </header>

        <div class="card p-8 rounded-lg max-w-4xl">
            <form id="uploadVideoForm" class="space-y-8">
                <!-- Video Details -->
                <div>
                    <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                        <i class="fas fa-info-circle text-purple-400"></i> Video Details
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label class="block text-sm font-medium text-white/80 mb-2">Video Title *</label>
                            <input type="text" required placeholder="Enter video title" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:outline-none focus:border-purple-500/50 transition">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-white/80 mb-2">Category *</label>
                            <select required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-purple-500/50 transition">
                                <option value="">Select category</option>
                                <option value="music">Music Video</option>
                                <option value="tutorial">Tutorial</option>
                                <option value="live">Live Performance</option>
                                <option value="vlog">Vlog</option>
                                <option value="educational">Educational</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label class="block text-sm font-medium text-white/80 mb-2">Release Date *</label>
                            <input type="date" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-purple-500/50 transition">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-white/80 mb-2">Video Language</label>
                            <select class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-purple-500/50 transition">
                                <option value="">Select language</option>
                                <option value="english">English</option>
                                <option value="spanish">Spanish</option>
                                <option value="french">French</option>
                                <option value="german">German</option>
                                <option value="chinese">Chinese</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-white/80 mb-2">Description</label>
                        <textarea placeholder="Tell your viewers about this video" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:outline-none focus:border-purple-500/50 transition h-20"></textarea>
                    </div>
                </div>

                <!-- Video Tags -->
                <div>
                    <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                        <i class="fas fa-tags text-purple-400"></i> Tags
                    </h3>
                    
                    <div id="tagsContainer" class="space-y-3">
                        <div class="flex gap-2">
                            <input type="text" placeholder="Add a tag and press Enter" class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-white placeholder-white/40 focus:outline-none focus:border-purple-500/50 transition">
                            <button type="button" onclick="addTag()" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Video File Upload -->
                <div>
                    <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                        <i class="fas fa-film text-purple-400"></i> Video File *
                    </h3>
                    
                    <div class="border-2 border-dashed border-purple-500/40 rounded-lg p-8 text-center cursor-pointer hover:border-purple-500/60 transition" onclick="document.getElementById('videoFile').click()">
                        <i class="fas fa-cloud-upload-alt text-purple-400 text-4xl mb-4 block"></i>
                        <p class="text-white/70 mb-2">Drag or click to upload video file</p>
                        <p class="text-white/40 text-sm">MP4, MKV, WebM (Max 500MB)</p>
                        <input type="file" id="videoFile" required accept="video/*" class="hidden">
                    </div>
                </div>

                <!-- Thumbnail -->
                <div>
                    <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                        <i class="fas fa-image text-purple-400"></i> Thumbnail *
                    </h3>
                    
                    <div class="border-2 border-dashed border-purple-500/40 rounded-lg p-8 text-center cursor-pointer hover:border-purple-500/60 transition" onclick="document.getElementById('thumbnail').click()">
                        <i class="fas fa-image text-purple-400 text-4xl mb-4 block"></i>
                        <p class="text-white/70 mb-2">Drag or click to upload thumbnail</p>
                        <p class="text-white/40 text-sm">JPG, PNG (Max 10MB)</p>
                        <input type="file" id="thumbnail" required accept="image/*" class="hidden">
                    </div>
                </div>

                <!-- Copyright & Rights -->
                <div class="bg-purple-500/10 border border-purple-500/20 rounded-lg p-6">
                    <h3 class="text-lg font-bold mb-4 flex items-center gap-2 text-white">
                        <i class="fas fa-lock text-purple-400"></i> Copyright & Rights
                    </h3>
                    
                    <div class="space-y-3">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" required class="mt-1">
                            <span class="text-white/80">I certify that I own or control the rights to this video</span>
                        </label>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" required class="mt-1">
                            <span class="text-white/80">This video does not infringe on any copyright or intellectual property rights</span>
                        </label>
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div class="flex gap-4 justify-end">
                    <button type="button" onclick="window.history.back()" class="px-8 py-3 bg-white/10 text-white/70 hover:text-white rounded-lg transition border border-white/20">
                        Cancel
                    </button>
                    <button type="submit" class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition font-medium flex items-center gap-2">
                        <i class="fas fa-upload"></i> Upload Video
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function addTag() {
            const container = document.getElementById('tagsContainer');
            const div = document.createElement('div');
            div.className = 'flex gap-2';
            div.innerHTML = `
                <input type="text" placeholder="Add a tag and press Enter" class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-white placeholder-white/40 focus:outline-none focus:border-purple-500/50 transition">
                <button type="button" onclick="this.parentElement.remove()" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition">
                    <i class="fas fa-trash"></i>
                </button>
            `;
            container.appendChild(div);
        }

        document.getElementById('uploadVideoForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Video uploaded successfully!');
        });

        function logout() {
            fetch('/api/auth/logout', { method: 'POST' })
                .then(() => { window.location.href = '/'; })
                .catch(err => { console.error('Logout error:', err); window.location.href = '/'; });
        }
    </script>
</body>
</html>
