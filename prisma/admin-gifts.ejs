<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Gift Management | EchoVault Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: linear-gradient(135deg, #0F0C29 0%, #302B63 50%, #24243E 100%); color: white; font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.05); border-radius: 1rem; }
        .admin-sidebar { background: rgba(15,12,41,0.8); backdrop-filter: blur(10px); }
    </style>
</head>
<body class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-72 admin-sidebar p-8 border-r border-white/5 shadow-2xl flex flex-col justify-between">
        <div>
            <div class="flex items-center gap-3 mb-12 pb-8 border-b border-white/10">
                <div class="bg-gradient-to-br from-emerald-500 to-teal-500 p-3 rounded-xl shadow-lg">
                    <i class="fas fa-shield-alt text-white text-xl"></i>
                </div>
                <span class="font-black tracking-tight text-xl bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent">ADMIN CENTRAL</span>
            </div>
            <nav class="space-y-2">
                <div class="text-xs text-white/30 uppercase tracking-wider mb-4 font-medium">Overview</div>
                <a href="/api/admin/dashboard" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-chart-line w-5"></i><span>Dashboard</span>
                </a>
                <a href="/api/admin/users" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-users w-5"></i> User Directory
                </a>
                <div class="text-xs text-white/30 uppercase tracking-wider mt-8 mb-4 font-medium">Management</div>
                <a href="/api/admin/artist-verification" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-microphone w-5"></i> Artist Verification
                </a>
                <a href="/api/admin/create-admin" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-user-plus w-5"></i> Add Admin
                </a>
                <a href="/api/admin/payouts" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-coins w-5"></i> Payouts
                </a>
                <a href="/api/admin/gifts" class="flex items-center gap-3 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 font-medium">
                    <i class="fas fa-gift w-5"></i> Gift Management
                </a>
                <a href="/api/admin/reports" class="flex items-center gap-3 p-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    <i class="fas fa-flag w-5"></i> Reports
                </a>
            </nav>
        </div>
        <button onclick="logout()" class="w-full flex items-center justify-center gap-2 p-3 bg-red-600/20 text-red-400 hover:bg-red-600/30 rounded-lg transition border border-red-600/30">
            <i class="fas fa-sign-out-alt"></i> Logout
        </button>
    </aside>

    <main class="flex-1 p-12 overflow-y-auto">
        <!-- Header -->
        <header class="flex justify-between items-center mb-12 pb-8 border-b border-white/10">
            <div>
                <h1 class="text-5xl font-black bg-gradient-to-r from-emerald-400 via-teal-400 to-emerald-600 bg-clip-text text-transparent tracking-tight mb-2">🎁 Gift Management</h1>
                <p class="text-xl text-white/60 font-light">Create, manage, and configure platform gifts</p>
            </div>
        </header>

        <!-- Success Message -->
        <div id="successMessage" class="mb-6 p-4 bg-emerald-500/20 border border-emerald-500/50 rounded-lg text-emerald-300 hidden">
            Gift created successfully!
        </div>

        <!-- Error Message -->
        <div id="errorMessage" class="mb-6 p-4 bg-red-500/20 border border-red-500/50 rounded-lg text-red-300 hidden"></div>

        <!-- Add Gift Form -->
        <div class="glass p-8 border border-emerald-500/20 mb-8">
            <h2 class="text-2xl font-black mb-6 flex items-center gap-3 text-white">
                <i class="fas fa-plus-circle text-emerald-400"></i> Create New Gift
            </h2>
            <form id="giftForm" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-2">Gift Name</label>
                    <input type="text" name="name" id="giftName" class="w-full bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white placeholder-white/30 focus:border-emerald-500 focus:bg-white/5 transition" placeholder="e.g. Golden Mic" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-2">Icon (PNG/GIF)</label>
                    <input type="file" name="icon" id="giftIcon" accept=".png,.gif,.jpg,.jpeg,.webp" class="w-full bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white text-xs file:bg-emerald-600 file:text-white file:border-0 file:rounded file:px-3 file:py-1 file:cursor-pointer focus:border-emerald-500 focus:bg-white/5 transition" required>
                    <small class="text-white/40 text-xs mt-1">Max 2MB</small>
                </div>
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-2">Display Price ($)</label>
                    <input type="number" step="0.01" name="price" id="giftPrice" class="w-full bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white placeholder-white/30 focus:border-emerald-500 focus:bg-white/5 transition" placeholder="10.00" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-2">Actual Value ($)</label>
                    <input type="number" step="0.01" name="actualAmount" id="giftAmount" class="w-full bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white placeholder-white/30 focus:border-emerald-500 focus:bg-white/5 transition" placeholder="10.00" required>
                </div>
                <div class="flex flex-col justify-end">
                    <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white font-bold py-2 px-4 rounded-lg transition-all transform hover:scale-105">
                        <i class="fas fa-plus mr-2"></i> Add Gift
                    </button>
                </div>
            </form>
        </div>

        <!-- Existing Gifts -->
        <div class="glass p-8 border border-white/10">
            <h2 class="text-2xl font-black mb-6 flex items-center gap-3 text-white">
                <i class="fas fa-list text-emerald-400"></i> Active Gifts (<span id="giftCount">0</span>)
            </h2>
            <div id="giftsTable" class="text-center py-12">
                <i class="fas fa-inbox text-5xl text-white/20 mb-4 block"></i>
                <p class="text-white/50 text-lg">No gifts created yet. Create your first gift above!</p>
            </div>
        </div>
    </main>

    <script>
        // Handle form submission with FormData (for file upload)
        // Uses cookie-based authentication automatically with credentials: 'include'
        document.getElementById('giftForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const name = document.getElementById('giftName').value;
            const iconFile = document.getElementById('giftIcon').files[0];
            const price = document.getElementById('giftPrice').value;
            const actualAmount = document.getElementById('giftAmount').value;
            
            console.log('Submitting gift:', { name, iconFile: iconFile?.name, price, actualAmount });
            
            if (!iconFile) {
                showError('Please select an icon file');
                return;
            }
            
            try {
                // Create FormData for file upload
                const formData = new FormData();
                formData.append('name', name);
                formData.append('icon', iconFile);
                formData.append('price', parseFloat(price));
                formData.append('actualAmount', parseFloat(actualAmount));
                
                console.log('Sending request with credentials...');
                const response = await fetch('/api/admin/gifts/create', {
                    method: 'POST',
                    credentials: 'include', // Send httpOnly cookies automatically
                    body: formData
                });
                
                const data = await response.json();
                console.log('Response status:', response.status);
                console.log('Response data:', data);
                
                if (response.ok && data.success) {
                    document.getElementById('successMessage').classList.remove('hidden');
                    document.getElementById('errorMessage').classList.add('hidden');
                    document.getElementById('giftForm').reset();
                    
                    loadGifts();
                    
                    setTimeout(() => {
                        document.getElementById('successMessage').classList.add('hidden');
                    }, 3000);
                } else {
                    showError(data.message || 'Failed to create gift');
                }
            } catch (error) {
                console.error('Error:', error);
                showError('Network error: ' + error.message);
            }
        });
        
        function showError(message) {
            document.getElementById('errorMessage').textContent = message;
            document.getElementById('errorMessage').classList.remove('hidden');
            document.getElementById('successMessage').classList.add('hidden');
        }
        
        async function loadGifts() {
            try {
                console.log('Loading gifts...');
                const response = await fetch('/api/admin/gifts/api', {
                    credentials: 'include' // Send httpOnly cookies automatically
                });
                const data = await response.json();
                
                if (data.success && data.data) {
                    const gifts = data.data;
                    document.getElementById('giftCount').textContent = gifts.length;
                    
                    if (gifts.length > 0) {
                        let html = `
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm">
                                    <thead class="bg-white/5 border-b border-white/10">
                                        <tr>
                                            <th class="px-4 py-3 text-left font-semibold text-white">Icon</th>
                                            <th class="px-4 py-3 text-left font-semibold text-white">Gift Name</th>
                                            <th class="px-4 py-3 text-left font-semibold text-white">Display Price</th>
                                            <th class="px-4 py-3 text-left font-semibold text-white">Actual Value</th>
                                            <th class="px-4 py-3 text-left font-semibold text-white">Created</th>
                                        </tr>
                                    </thead>
                                    <tbody>`;
                        
                        gifts.forEach(gift => {
                            // Check if icon is a URL or emoji
                            let iconHtml = gift.icon.startsWith('/') 
                                ? `<img src="${gift.icon}" alt="${gift.name}" class="w-8 h-8 object-contain">`
                                : `<span class="text-2xl">${gift.icon}</span>`;
                            
                            html += `
                                <tr class="border-t border-white/10 hover:bg-white/5 transition">
                                    <td class="px-4 py-3">${iconHtml}</td>
                                    <td class="px-4 py-3 text-white font-medium">${gift.name}</td>
                                    <td class="px-4 py-3 text-white/70">$${parseFloat(gift.price).toFixed(2)}</td>
                                    <td class="px-4 py-3 text-emerald-400 font-bold">$${parseFloat(gift.actualAmount).toFixed(2)}</td>
                                    <td class="px-4 py-3 text-white/60 text-xs">${new Date(gift.createdAt).toLocaleDateString()}</td>
                                </tr>`;
                        });
                        
                        html += `</tbody></table></div>`;
                        document.getElementById('giftsTable').innerHTML = html;
                    }
                }
            } catch (error) {
                console.error('Error loading gifts:', error);
            }
        }
        
        function logout() {
            localStorage.removeItem('token');
            sessionStorage.removeItem('token');
            fetch('/api/auth/logout', { method: 'POST', credentials: 'include' })
                .then(() => { window.location.href = '/'; })
                .catch(err => { console.error('Logout error:', err); window.location.href = '/'; });
        }
        
        window.addEventListener('load', () => {
            console.log('Page loaded, loading gifts...');
            loadGifts();
        });
    </script>
</body>
</html>
